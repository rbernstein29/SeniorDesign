<% content_for :title, "Aegis - Verify Your Email" %>

<div class="login-wrap">
  <div class="login-card">
    <div class="login-head">
      <div class="login-brand">
        <%= image_tag 'logo_dark_mode.png',  alt: 'Aegis', class: 'login-logo logo-dark' %>
        <%= image_tag 'logo_light_mode.png', alt: 'Aegis', class: 'login-logo logo-light' %>
        <h1>Aegis</h1>
      </div>
      <div class="login-sub">Check your email</div>
    </div>

    <div class="login-body" style="text-align:center;">
      <% if flash[:notice] %>
        <div class="alert-success"><%= flash[:notice] %></div>
      <% end %>
      <p>We sent a verification link to your email address. Click the link to activate your account.</p>
      <p style="font-size:13px;opacity:0.6;">The link expires in 30 minutes. Check your spam folder if you don't see it.</p>

      <%= form_with url: resend_verification_path, method: :post, style: "margin-top:16px;" do |f| %>
        <%= f.email_field :email_address, class: "input", placeholder: "Enter your email to resend", required: true %>
        <%= f.submit "Resend verification email", class: "btn btn-secondary btn-sm", style: "margin-top:8px;width:100%;" %>
      <% end %>

      <%= link_to "Back to sign in", login_path, class: "btn btn-primary", style: "margin-top:8px;width:100%;display:block;" %>
    </div>
  </div>
</div>
