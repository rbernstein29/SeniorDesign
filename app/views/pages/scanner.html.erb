<% content_for :title, "Aegis - Scanner" %>

<%= render 'shared/sidebar', current_page: 'scanner' %>

<div class="layout page-red">

    <div class="page-header">
        <div>
            <div class="page-title"><%= image_tag 'SDimagesWhite/snanerWhite.png', alt: '', class: 'page-title-img icon-white' %><%= image_tag 'SDimagesBlack/ScansBlack.png', alt: '', class: 'page-title-img icon-black' %> Scanner</div>
            <div class="page-sub">// Metasploit-powered vulnerability assessment</div>
        </div>
        <%= link_to scan_profiles_path, class: "btn btn-secondary btn-yellow-glow" do %>
            <%= image_tag 'SDimagesWhite/scanprofileWhite.png', alt: '', class: 'nav-icon-img icon-white', style: 'width:16px;height:16px;vertical-align:middle;margin-right:4px;' %>
            <%= image_tag 'SDimagesBlack/scanprofileBlack.png', alt: '', class: 'nav-icon-img icon-black', style: 'width:16px;height:16px;vertical-align:middle;margin-right:4px;' %>
            Manage Profiles
        <% end %>
    </div>

    <% if flash[:notice] %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
        <div class="alert alert-error"><%= flash[:alert] %></div>
    <% end %>

    <div class="info-box" style="margin-bottom:16px;">
        <div class="info-box-icon">
            <%= image_tag 'SDimagesWhite/InformationWhite.png', alt: '', class: 'icon-white', style: 'width:20px;height:20px;' %>
            <%= image_tag 'SDimagesBlack/InformationBlack.png', alt: '', class: 'icon-black', style: 'width:20px;height:20px;' %>
        </div>
        <div>
            <div class="info-box-title">How Scanning Works</div>
            <ul class="info-box-list">
                <li>Deploy a network agent on the target network first</li>
                <li>Add scan targets under Asset Management</li>
                <li>Scans route through the agent's SSH tunnel — no VPN needed</li>
                <li>Results are parsed and stored as vulnerability findings</li>
            </ul>
        </div>
    </div>

    <%= form_with url: trigger_scan_path, method: :post, local: true, id: "scanner-form" do %>

        <!-- ═══ 1. TARGET SELECTION ═══ -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-header">
                <span class="card-header-icon">
                    <%= image_tag 'SDimagesWhite/targetWhite.png', alt: '', class: 'nav-icon-img icon-white', style: 'width:20px;height:20px;' %>
                    <%= image_tag 'SDimagesBlack/targetBlack.png', alt: '', class: 'nav-icon-img icon-black', style: 'width:20px;height:20px;' %>
                </span>
                <div>
                    <div class="card-title">Target Selection</div>
                    <div class="card-subtitle">SELECT WHAT TO SCAN</div>
                </div>
            </div>
            <div class="card-body">

                <!-- Mode tabs -->
                <div style="display:flex;gap:8px;margin-bottom:20px;">
                    <button type="button" class="scanner-tab active" id="tab-target-asset" onclick="switchTargetMode('asset')">By Asset</button>
                    <button type="button" class="scanner-tab" id="tab-target-site" onclick="switchTargetMode('site')">By Site</button>
                    <button type="button" class="scanner-tab" id="tab-target-cidr" onclick="switchTargetMode('cidr')">By IP</button>
                </div>

                <!-- By Asset: filter controls -->
                <div id="target-panel-asset">
                    <div style="display:flex;gap:10px;flex-wrap:wrap;">
                        <select id="filter-site" onchange="applyFilter()" style="min-width:160px;">
                            <option value="">All Sites</option>
                            <% @sites.each do |site| %>
                                <option value="<%= site.id %>"><%= site.name %></option>
                            <% end %>
                        </select>
                        <select id="filter-os" onchange="applyFilter()" style="min-width:140px;">
                            <option value="">All OS</option>
                            <option value="linux">Linux</option>
                            <option value="windows">Windows</option>
                            <option value="macos">macOS</option>
                        </select>
                        <select id="filter-crit" onchange="applyFilter()" style="min-width:150px;">
                            <option value="">All Criticality</option>
                            <option value="high">High</option>
                            <option value="medium">Medium</option>
                            <option value="low">Low</option>
                            <option value="unknown">Unknown</option>
                        </select>
                    </div>
                </div>

                <!-- By Site: filter controls -->
                <div id="target-panel-site" style="display:none;">
                    <% if @sites.any? %>
                        <div style="max-width:400px;">
                            <select id="site-filter-select" onchange="applyFilter()" style="width:100%;">
                                <option value="">Select a site…</option>
                                <% @sites.each do |site| %>
                                    <option value="<%= site.id %>">
                                        <%= site.name %><%= site.network_range.present? ? " (#{site.network_range})" : "" %>
                                    </option>
                                <% end %>
                            </select>
                        </div>
                    <% else %>
                        <div style="color:var(--muted);font-size:13px;">No sites configured.</div>
                    <% end %>
                </div>

                <!-- By CIDR: filter controls -->
                <div id="target-panel-cidr" style="display:none;">
                    <div style="max-width:400px;">
                        <input type="text" id="cidr-filter-input" placeholder="e.g. 192.168.1.1 or 192.168.1.0/24" oninput="applyFilter()"
                            style="width:100%;">
                    </div>
                </div>

                <!-- Shared asset list (all modes) -->
                <% if @assets.any? %>
                    <div style="display:flex;gap:8px;margin-top:12px;margin-bottom:8px;flex-wrap:wrap;">
                        <button type="button" onclick="selectAllVisible(true)" class="btn btn-secondary" style="padding:4px 10px;font-size:12px;">Select All</button>
                        <button type="button" onclick="selectAllVisible(false)" class="btn btn-secondary" style="padding:4px 10px;font-size:12px;">Clear</button>
                    </div>
                    <div style="max-height:240px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;padding:8px;">
                        <% @assets.each do |asset| %>
                            <label class="asset-check-row"
                                data-site="<%= asset.site_id %>"
                                data-os="<%= asset.scan_config&.dig('os') %>"
                                data-crit="<%= asset.criticality %>"
                                data-ip="<%= asset.ip_address.to_s.split('/').first %>">
                                <input type="checkbox" name="asset_ids[]" value="<%= asset.id %>" class="asset-checkbox">
                                <span class="network-code" style="font-size:13px;"><%= asset.ip_address %></span>
                                <% if asset.hostname.present? && asset.hostname != 'No Domain Name' %>
                                    <span style="color:var(--muted);font-size:12px;"><%= asset.hostname %></span>
                                <% end %>
                                <% os = asset.scan_config&.dig('os') %>
                                <% if os.present? %>
                                    <span style="font-family:var(--mono);font-size:11px;color:var(--muted);"><%= os.upcase %></span>
                                <% end %>
                                <% if asset.site %>
                                    <span style="font-size:11px;color:var(--muted);margin-left:auto;"><%= asset.site.name %></span>
                                <% end %>
                            </label>
                        <% end %>
                    </div>
                    <div style="margin-top:8px;font-size:12px;color:var(--muted);">
                        <span id="asset-selected-count">0</span> asset(s) selected
                    </div>
                <% else %>
                    <div style="text-align:center;padding:24px;color:var(--muted);margin-top:12px;">
                        No assets configured — <%= link_to "add one first", new_asset_path, style: "color:var(--accent);" %>
                    </div>
                <% end %>

            </div>
        </div>

        <!-- ═══ 2. EXPLOIT FILTERS ═══ -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-header">
                <span class="card-header-icon">
                    <%= image_tag 'SDimagesWhite/SeverityWhite.png', alt: '', class: 'nav-icon-img icon-white', style: 'width:20px;height:20px;' %>
                    <%= image_tag 'SDimagesBlack/SeverityBlack.png', alt: '', class: 'nav-icon-img icon-black', style: 'width:20px;height:20px;' %>
                </span>
                <div>
                    <div class="card-title">Exploit Filters</div>
                    <div class="card-subtitle">SELECT TRAITS — EXPLOITS AUTO-MATCHED</div>
                </div>
            </div>
            <div class="card-body">

                <div class="form-grid" style="grid-template-columns:1fr 1fr;gap:20px;">

                    <!-- Severity -->
                    <div class="form-group">
                        <label class="form-label">Severity</label>
                        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:4px;">
                            <% [['critical','#ef4444'],['high','#f59e0b'],['medium','#fbbf24'],['low','#22c55e']].each do |sev, color| %>
                                <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;">
                                    <input type="checkbox" name="severities[]" value="<%= sev %>"
                                           class="severity-checkbox" checked
                                           style="accent-color:<%= color %>;"
                                           onchange="updateExploitCount()">
                                    <span style="font-family:var(--mono);color:<%= color %>;text-transform:uppercase;font-size:12px;"><%= sev %></span>
                                </label>
                            <% end %>
                        </div>
                    </div>

                    <!-- Platform -->
                    <div class="form-group">
                        <label class="form-label">Platform</label>
                        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:4px;">
                            <% [['any','Any'],['windows','Windows'],['linux','Linux'],['macos','macOS']].each do |val, label| %>
                                <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;">
                                    <input type="radio" name="platform" value="<%= val %>"
                                           <%= val == 'any' ? 'checked' : '' %>
                                           onchange="updateExploitCount()">
                                    <span><%= label %></span>
                                </label>
                            <% end %>
                        </div>
                    </div>

                </div>

                <!-- Optional profile override -->
                <div class="form-group" style="max-width:400px;margin-top:8px;">
                    <label class="form-label">Profile Override <span style="font-weight:400;color:var(--muted);">(optional — overrides severity/platform)</span></label>
                    <select name="profile_id" id="profile-select" onchange="updateExploitCount()">
                        <option value="">— use trait filters above —</option>
                        <% @profiles.each do |profile| %>
                            <option value="<%= profile.id %>"
                                data-count="<%= profile.exploit_ids.size %>">
                                <%= profile.name %> (<%= profile.exploit_ids.size %> exploits)
                            </option>
                        <% end %>
                    </select>
                    <% if @profiles.empty? %>
                        <div style="font-size:11px;color:var(--muted);margin-top:4px;">
                            No profiles yet — <%= link_to "create one", new_scan_profile_path, style: "color:var(--accent);" %>
                        </div>
                    <% end %>
                </div>

                <!-- Live count -->
                <div style="margin-top:12px;padding:10px 14px;background:var(--surface2);border-radius:6px;border:1px solid var(--border);display:inline-flex;align-items:center;gap:8px;">
                    <span style="font-family:var(--mono);font-size:11px;color:var(--muted);">MATCHING EXPLOITS</span>
                    <span id="exploit-match-count" style="font-family:var(--mono);font-size:18px;font-weight:700;color:var(--accent);">—</span>
                </div>
                <div style="margin-top:8px;font-size:11px;color:var(--muted);">
                    Exploits are pulled directly from your Metasploit installation at runtime.
                    <strong style="color:var(--orange);">Platform = Any</strong> will attempt all available modules — expect a significantly longer scan.
                </div>

            </div>
        </div>

        <!-- ═══ 3. SCAN OPTIONS ═══ -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-header" style="cursor:pointer;" onclick="toggleScanOptions()">
                <span class="card-header-icon">
                    <%= image_tag 'SDimagesWhite/SettingsWhite.png', alt: '', class: 'nav-icon-img icon-white', style: 'width:20px;height:20px;' %>
                    <%= image_tag 'SDimagesBlack/SettingsBlack.png', alt: '', class: 'nav-icon-img icon-black', style: 'width:20px;height:20px;' %>
                </span>
                <div>
                    <div class="card-title">Scan Options</div>
                    <div class="card-subtitle">OPTIONAL OVERRIDES</div>
                </div>
                <span id="scan-options-arrow" style="margin-left:auto;font-family:var(--mono);color:var(--muted);">▼</span>
            </div>
            <div id="scan-options-body" style="display:none;" class="card-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Route via Agent</label>
                        <%= select_tag :use_agent, options_for_select([
                            ['No — scan directly over internet (public / blackbox)', 'false'],
                            ['Yes — route through agent via SOCKS5 (internal / whitebox)', 'true']
                        ], 'false') %>
                        <div style="font-size:11px;color:var(--muted);margin-top:4px;">When Yes: all packets are proxied through your deployed agent to reach internal devices</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Port Override</label>
                        <%= text_field_tag :port_override, nil, placeholder: "e.g. 80, 443" %>
                        <div style="font-size:11px;color:var(--muted);margin-top:4px;">Overrides per-asset port config for this scan only</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Timeout (seconds)</label>
                        <%= number_field_tag :timeout, 120, min: 10, max: 600 %>
                        <div style="font-size:11px;color:var(--muted);margin-top:4px;">Seconds per exploit attempt (default: 120)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Submit -->
        <div style="display:flex;gap:12px;align-items:center;">
            <button type="submit" class="btn-scan">▶ Run Scan</button>
            <span style="font-size:12px;color:var(--muted);">Scan will be queued and run in the background</span>
        </div>

    <% end %>

</div>

<style>
.scanner-tab {
    padding: 6px 16px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--muted);
    font-family: var(--mono);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.15s;
}
.scanner-tab.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(var(--accent-rgb, 0,200,255), 0.08);
}
.asset-check-row, .exploit-check-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 8px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    transition: background 0.1s;
}
.asset-check-row:hover, .exploit-check-row:hover {
    background: var(--surface2);
}
.asset-check-row[style*="display:none"] { display: none !important; }
</style>

<script>
let currentTargetMode = 'asset';

function switchTargetMode(mode) {
    currentTargetMode = mode;
    ['asset','site','cidr'].forEach(m => {
        document.getElementById('target-panel-' + m).style.display = m === mode ? '' : 'none';
        document.getElementById('tab-target-' + m).classList.toggle('active', m === mode);
    });
    applyFilter();
}

function applyFilter() {
    let filterFn;
    if (currentTargetMode === 'asset') {
        const site = document.getElementById('filter-site').value;
        const os   = document.getElementById('filter-os').value;
        const crit = document.getElementById('filter-crit').value;
        filterFn = row =>
            (!site || row.dataset.site == site) &&
            (!os   || row.dataset.os   == os)   &&
            (!crit || row.dataset.crit == crit);
    } else if (currentTargetMode === 'site') {
        const site = document.getElementById('site-filter-select').value;
        filterFn = row => !site || row.dataset.site == site;
    } else {
        const cidr = document.getElementById('cidr-filter-input').value.trim();
        filterFn = row => !cidr || cidrMatch(row.dataset.ip, cidr);
    }
    document.querySelectorAll('.asset-check-row').forEach(row => {
        row.style.display = filterFn(row) ? '' : 'none';
    });
    updateAssetCount();
}

function cidrMatch(ip, cidr) {
    try {
        if (!cidr.includes('/')) return ip.startsWith(cidr);
        const [base, bits] = cidr.split('/');
        const mask    = bits === '0' ? 0 : (~0 << (32 - parseInt(bits))) >>> 0;
        const ipInt   = ip.split('.').reduce((a, o) => (a * 256 + parseInt(o)), 0) >>> 0;
        const baseInt = base.split('.').reduce((a, o) => (a * 256 + parseInt(o)), 0) >>> 0;
        return (ipInt & mask) === (baseInt & mask);
    } catch(e) { return false; }
}

function selectAllVisible(checked) {
    document.querySelectorAll('.asset-check-row').forEach(row => {
        if (row.style.display !== 'none') {
            row.querySelector('.asset-checkbox').checked = checked;
        }
    });
    updateAssetCount();
}

function updateAssetCount() {
    const count = document.querySelectorAll('.asset-checkbox:checked').length;
    const el = document.getElementById('asset-selected-count');
    if (el) el.textContent = count;
}

// Live exploit count via AJAX
function updateExploitCount() {
    var profileSel = document.getElementById('profile-select');
    if (profileSel && profileSel.value) {
        var opt = profileSel.options[profileSel.selectedIndex];
        var el = document.getElementById('exploit-match-count');
        if (el) el.textContent = opt.dataset.count || '?';
        return;
    }
    var severities = Array.from(document.querySelectorAll('.severity-checkbox:checked')).map(function(cb) { return cb.value; });
    var platformEl = document.querySelector('input[name="platform"]:checked');
    var platform = platformEl ? platformEl.value : 'any';
    var params = new URLSearchParams();
    severities.forEach(function(s) { params.append('severities[]', s); });
    params.set('platform', platform);
    fetch('<%= exploit_count_path %>?' + params.toString())
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var el = document.getElementById('exploit-match-count');
            if (el) el.textContent = data.count;
        })
        .catch(function() {});
}

// Scan options toggle
function toggleScanOptions() {
    const body  = document.getElementById('scan-options-body');
    const arrow = document.getElementById('scan-options-arrow');
    const open  = body.style.display !== 'none';
    body.style.display  = open ? 'none' : '';
    arrow.textContent   = open ? '▼' : '▲';
}

document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.asset-checkbox').forEach(cb => {
        cb.addEventListener('change', updateAssetCount);
    });
    updateExploitCount();
});
</script>
