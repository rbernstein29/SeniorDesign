<% content_for :title, "Aegis - Scans" %>

<%= render 'shared/sidebar', current_page: 'scans' %>

<div class="layout">

    <div class="page-header">
        <div>
            <div class="page-title">Scans</div>
            <div class="page-sub">Run and manage vulnerability scans</div>
        </div>
        <%= link_to "+ New Scan", "/scanner", class: "btn btn-primary" %>
    </div>

    <% if flash[:notice] %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
        <div class="alert alert-error"><%= flash[:alert] %></div>
    <% end %>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Total Scans</div>
            <div class="stat-number"><%= @total_scans %></div>
        </div>
        <div class="stat-card cyan">
            <div class="stat-label">Running</div>
            <div class="stat-number"><%= @running_scans %></div>
        </div>
        <div class="stat-card green">
            <div class="stat-label">Completed</div>
            <div class="stat-number"><%= @completed_scans %></div>
        </div>
        <div class="stat-card red">
            <div class="stat-label">Failed / Cancelled</div>
            <div class="stat-number"><%= @failed_scans %></div>
        </div>
    </div>

    <div class="info-box">
        <div class="info-box-icon">ℹ</div>
        <div>
            <div class="info-box-title">How Scanning Works</div>
            <ul class="info-box-list">
                <li>Deploy a network agent on the target network first</li>
                <li>Add scan targets under Asset Management</li>
                <li>Scans route through the agent's SSH tunnel — no VPN needed</li>
                <li>Results are parsed and stored as vulnerability findings</li>
            </ul>
        </div>
    </div>

    <div class="main-card">
        <div class="card-header">
            <div class="card-title">Scan History</div>
            <div class="card-subtitle">ALL TIME</div>
        </div>

        <% if @scans.nil? || @scans.empty? %>
            <div class="state-box">
                <span class="state-icon">🔬</span>
                <div class="state-title">No Scans Yet</div>
                <div class="state-sub">Deploy an agent and add assets to run your first scan.</div>
                <%= link_to "Run Your First Scan", scanner_path, class: "btn btn-primary",
                    style: "display: inline-flex;" %>
            </div>
        <% else %>
            <table style="width:100%;">
                <thead>
                    <tr>
                        <th>Scan Name</th>
                        <th>Status</th>
                        <th>Started</th>
                        <th>Assets</th>
                        <th>Exploits Tested</th>
                        <th>Findings</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% @scans.each do |scan| %>
                    <tr>
                        <td style="font-family:var(--mono);font-size:12px;color:var(--text);font-weight:600;">
                            <%= scan.scan_name %>
                        </td>
                        <td>
                            <% case scan.status
                               when 'running' %>
                                <span class="status-badge status-running">
                                    <span class="status-dot dot-cyan"></span>Running
                                </span>
                            <% when 'completed' %>
                                <span class="status-badge status-complete">
                                    <span class="status-dot dot-green"></span>Complete
                                </span>
                            <% when 'failed', 'cancelled' %>
                                <span class="status-badge status-failed">
                                    <span class="status-dot dot-red"></span><%= scan.status.capitalize %>
                                </span>
                            <% else %>
                                <span class="status-badge status-queued">
                                    <span class="status-dot dot-gray"></span><%= scan.status.capitalize %>
                                </span>
                            <% end %>
                        </td>
                        <td style="font-family:var(--mono);font-size:12px;">
                            <%= scan.start_time&.strftime("%b %d, %Y  %H:%M") || raw('&mdash;') %>
                        </td>
                        <td style="font-family:var(--mono);">
                            <%= scan.scanned_assets %> / <%= scan.total_assets %>
                        </td>
                        <td style="font-family:var(--mono);">
                            <%= scan.total_exploits_tested %>
                        </td>
                        <td>
                            <% if scan.findings_count > 0 %>
                                <span class="severity-tag" style="color:var(--red);border-color:rgba(239,68,68,0.2);background:rgba(239,68,68,0.07);">
                                    <%= scan.findings_count %>
                                </span>
                            <% else %>
                                <span style="font-family:var(--mono);color:var(--muted);">0</span>
                            <% end %>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <% if scan.status == 'running' %>
                                    <%= button_to "Stop", stop_scan_path, method: :post,
                                        params: { scan_id: scan.id },
                                        class: "btn btn-danger btn-sm",
                                        data: { turbo_confirm: "Stop this scan?" } %>
                                <% end %>
                                <% if scan.reports.any? %>
                                    <%= link_to "Report", reports_path,
                                        class: "btn btn-secondary btn-sm" %>
                                <% end %>
                            </div>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        <% end %>
    </div>

</div>
