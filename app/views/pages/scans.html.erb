<% content_for :title, "Aegis - Scans" %>

<%= render 'shared/sidebar', current_page: 'scans' %>

<div class="layout page-orange">

    <div class="page-header">
        <div>
            <div class="page-title">Scan History</div>
            <div class="page-sub">Run and manage vulnerability scans</div>
        </div>
        <%= link_to "+ New Scan", "/scanner", class: "btn btn-primary" %>
    </div>

    <%= turbo_stream_from "scan_progress_#{Current.user.id}" %>

    <% if flash[:notice] %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
        <div class="alert alert-error"><%= flash[:alert] %></div>
    <% end %>

    <div id="scan_progress_area"></div>

    <div class="stats-grid">
        <div class="stat-card orange">
            <div class="stat-label">Total Scans</div>
            <div class="stat-number" data-stat="total"><%= @total_scans %></div>
        </div>
        <div class="stat-card cyan">
            <div class="stat-label">Running</div>
            <div class="stat-number" data-stat="running"><%= @running_scans %></div>
        </div>
        <div class="stat-card green">
            <div class="stat-label">Completed</div>
            <div class="stat-number" data-stat="completed"><%= @completed_scans %></div>
        </div>
        <div class="stat-card red">
            <div class="stat-label">Failed / Cancelled</div>
            <div class="stat-number" data-stat="failed"><%= @failed_scans %></div>
        </div>
    </div>

    <div class="info-box">
        <div class="info-box-icon">
            <%= image_tag 'SDimagesWhite/InformationWhite.png', alt: '', class: 'icon-white', style: 'width:20px;height:20px;' %>
            <%= image_tag 'SDimagesBlack/InformationBlack.png', alt: '', class: 'icon-black', style: 'width:20px;height:20px;' %>
        </div>
        <div>
            <div class="info-box-title">How Scanning Works</div>
            <ul class="info-box-list">
                <li>Deploy a network agent on the target network first</li>
                <li>Add scan targets under Asset Management</li>
                <li>Scans route through the agent's SSH tunnel — no VPN needed</li>
                <li>Results are parsed and stored as vulnerability findings</li>
            </ul>
        </div>
    </div>

    <div class="main-card">
        <div class="card-header">
            <div class="card-title">Scan History</div>
            <div class="card-subtitle">ALL TIME</div>
        </div>

        <% if @scans.nil? || @scans.empty? %>
            <div class="state-box">
                <span class="state-icon"><%= image_tag 'SDimagesWhite/snanerWhite.png', alt: '', class: 'state-icon-img icon-white' %><%= image_tag 'SDimagesBlack/ScansBlack.png', alt: '', class: 'state-icon-img icon-black' %></span>
                <div class="state-title">No Scans Yet</div>
                <div class="state-sub">Deploy an agent and add assets to run your first scan.</div>
                <%= link_to "Run Your First Scan", scanner_path, class: "btn btn-primary",
                    style: "display: inline-flex;" %>
            </div>
        <% else %>
            <table style="width:100%;">
                <thead>
                    <tr>
                        <th>Scan Name</th>
                        <th>Status</th>
                        <th>Started</th>
                        <th>Assets</th>
                        <th>Exploits Tested</th>
                        <th>Findings</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% @scans.each do |scan| %>
                    <tr data-scan-id="<%= scan.id %>">
                        <td style="font-family:var(--mono);font-size:12px;color:var(--text);font-weight:600;">
                            <%= scan.scan_name %>
                        </td>
                        <td data-field="status">
                            <% case scan.status
                               when 'running' %>
                                <span class="status-badge status-running">
                                    <span class="status-dot dot-cyan"></span>Running
                                </span>
                            <% when 'completed' %>
                                <span class="status-badge status-complete">
                                    <span class="status-dot dot-green"></span>Complete
                                </span>
                            <% when 'failed', 'cancelled' %>
                                <span class="status-badge status-failed">
                                    <span class="status-dot dot-red"></span><%= scan.status.capitalize %>
                                </span>
                            <% else %>
                                <span class="status-badge status-queued">
                                    <span class="status-dot dot-gray"></span><%= scan.status.capitalize %>
                                </span>
                            <% end %>
                        </td>
                        <td style="font-family:var(--mono);font-size:12px;">
                            <%= scan.start_time&.strftime("%b %d, %Y  %H:%M") || raw('&mdash;') %>
                        </td>
                        <td data-field="assets" style="font-family:var(--mono);">
                            <%= scan.scanned_assets %> / <%= scan.total_assets %>
                        </td>
                        <td data-field="exploits" style="font-family:var(--mono);">
                            <%= scan.total_exploits_tested %>
                        </td>
                        <td data-field="findings">
                            <% if scan.findings_count > 0 %>
                                <span class="severity-tag" style="color:var(--red);border-color:rgba(239,68,68,0.2);background:rgba(239,68,68,0.07);">
                                    <%= scan.findings_count %>
                                </span>
                            <% else %>
                                <span style="font-family:var(--mono);color:var(--muted);">0</span>
                            <% end %>
                        </td>
                        <td data-field="actions">
                            <div class="action-buttons">
                                <% if scan.status == 'running' %>
                                    <%= button_to "Stop", stop_scan_path, method: :post,
                                        params: { scan_id: scan.id },
                                        class: "btn btn-danger btn-sm",
                                        data: { turbo_confirm: "Stop this scan?" } %>
                                <% end %>
                                <% if scan.status == 'completed' %>
                                    <% report = scan.reports.first %>
                                    <%= link_to "View Report",
                                        report ? reports_path(anchor: "report-#{report.id}") : reports_path,
                                        class: "btn btn-secondary btn-sm" %>
                                <% end %>
                            </div>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        <% end %>
    </div>

</div>

<script>
  const REPORTS_PATH = "<%= reports_path %>";

  function updateScanStats(stats) {
    ['total', 'running', 'completed', 'failed'].forEach(key => {
      const el = document.querySelector(`[data-stat="${key}"]`);
      if (el && stats[key] !== undefined) el.textContent = stats[key];
    });
  }

  function updateScanRow(scan) {
    const row = document.querySelector(`tr[data-scan-id="${scan.id}"]`);
    if (!row) return;

    const statusCell = row.querySelector('[data-field="status"]');
    if (statusCell) {
      const labels = { running: 'Running', completed: 'Complete', failed: 'Failed', cancelled: 'Cancelled' };
      const badges = { running: 'status-running', completed: 'status-complete', failed: 'status-failed', cancelled: 'status-failed' };
      const dots   = { running: 'dot-cyan',        completed: 'dot-green',        failed: 'dot-red',       cancelled: 'dot-red' };
      const badge  = badges[scan.status] || 'status-queued';
      const dot    = dots[scan.status]   || 'dot-gray';
      const label  = labels[scan.status] || scan.status.charAt(0).toUpperCase() + scan.status.slice(1);
      statusCell.innerHTML = `<span class="status-badge ${badge}"><span class="status-dot ${dot}"></span>${label}</span>`;
    }

    const assetsCell = row.querySelector('[data-field="assets"]');
    if (assetsCell) assetsCell.textContent = `${scan.scanned_assets} / ${scan.total_assets}`;

    const exploitsCell = row.querySelector('[data-field="exploits"]');
    if (exploitsCell) exploitsCell.textContent = scan.total_exploits_tested;

    const findingsCell = row.querySelector('[data-field="findings"]');
    if (findingsCell) {
      if (scan.findings_count > 0) {
        findingsCell.innerHTML = `<span class="severity-tag" style="color:var(--red);border-color:rgba(239,68,68,0.2);background:rgba(239,68,68,0.07);">${scan.findings_count}</span>`;
      } else {
        findingsCell.innerHTML = `<span style="font-family:var(--mono);color:var(--muted);">0</span>`;
      }
    }

    if (scan.status !== 'running') {
      const actionsCell = row.querySelector('[data-field="actions"]');
      if (actionsCell) {
        if (scan.status === 'completed') {
          const anchor = scan.report_id ? `${REPORTS_PATH}#report-${scan.report_id}` : REPORTS_PATH;
          actionsCell.innerHTML = `<div class="action-buttons"><a href="${anchor}" class="btn btn-secondary btn-sm">View Report</a></div>`;
        } else {
          actionsCell.innerHTML = `<div class="action-buttons"></div>`;
        }
      }
    }
  }

  function pollScans() {
    const ids = Array.from(document.querySelectorAll('tr[data-scan-id]')).map(r => r.dataset.scanId);
    const qs  = ids.length ? '?' + ids.map(id => `ids[]=${id}`).join('&') : '';
    fetch(`/scans/status${qs}`, { headers: { 'Accept': 'application/json' } })
      .then(r => r.json())
      .then(data => {
        if (data.stats) updateScanStats(data.stats);
        (data.scans || []).forEach(updateScanRow);
      })
      .catch(err => console.error('Scan status poll failed:', err));
  }

  setInterval(pollScans, 5000);
</script>
