<% content_for :title, "Aegis - Dashboard" %>

<%= render 'shared/sidebar', current_page: 'home' %>

<div class="layout page-home">
  <!-- Top Bar -->
  <div class="topbar">
    <div class="topbar-brand">
      <%= image_tag 'logo_dark_mode.png',  alt: 'Aegis', class: 'brand-logo logo-dark' %>
      <%= image_tag 'logo_light_mode.png', alt: 'Aegis', class: 'brand-logo logo-light' %>
      <div>
        <div class="brand-name">Aegis</div>
        <div class="brand-version">SECURITY PLATFORM v1.0</div>
      </div>
    </div>
    <div class="topbar-meta">
      <div class="live-badge">
        <div class="live-dot"></div>
        SYSTEMS ONLINE
      </div>
      <div class="topbar-time" id="clock"></div>
    </div>
  </div>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-greeting">Welcome back, <%= Current.session&.user&.name&.split(' ')&.first&.capitalize || 'Analyst' %></div>
    <h1 class="hero-title">Security Operations Center</h1>
    <p class="hero-sub">Monitor vulnerabilities, manage assets, and coordinate scanning agents from a single command center.</p>
  </div>

  <!-- Stats -->
  <% connected = @agents&.count(&:connected?) || 0 %>
  <div class="stats-row">
    <div class="stat-card cyan">
      <div class="stat-label">Total Assets</div>
      <div class="stat-value"><%= @assets&.count || 0 %></div>
      <div class="stat-delta up">Configured targets</div>
    </div>
    <div class="stat-card cyan">
      <div class="stat-label">Scan-Ready Assets</div>
      <% scan_ready = @assets&.count { |a| a.scan_config.present? } || 0 %>
      <div class="stat-value"><%= scan_ready %></div>
      <div class="stat-delta">With scan config</div>
    </div>
    <div class="stat-card teal">
      <div class="stat-label">Total Sites</div>
      <div class="stat-value"><%= @sites&.count || 0 %></div>
      <div class="stat-delta">Network sites</div>
    </div>
    <div class="stat-card magenta">
      <div class="stat-label">Total Agents</div>
      <div class="stat-value"><%= @agents&.count || 0 %></div>
      <div class="stat-delta">Registered agents</div>
    </div>
    <div class="stat-card magenta">
      <div class="stat-label">Connected Agents</div>
      <div class="stat-value"><%= connected %></div>
      <div class="stat-delta <%= connected > 0 ? 'up' : '' %>"><%= connected > 0 ? 'Online now' : 'None online' %></div>
    </div>
    <div class="stat-card magenta">
      <div class="stat-label">Offline Agents</div>
      <% offline = (@agents&.count || 0) - connected %>
      <div class="stat-value"><%= offline %></div>
      <div class="stat-delta <%= offline > 0 ? 'bad' : '' %>"><%= offline > 0 ? 'Not reachable' : 'All online' %></div>
    </div>
    <div class="stat-card violet">
      <div class="stat-label">Total Reports</div>
      <div class="stat-value"><%= @reports&.count || 0 %></div>
      <div class="stat-delta">Scan reports</div>
    </div>
    <div class="stat-card orange">
      <div class="stat-label">Last Scan</div>
      <% if @last_scan %>
        <div class="stat-value" style="font-size:16px;line-height:1.3;margin-top:4px;"><%= time_ago_in_words(@last_scan) %> ago</div>
      <% else %>
        <div class="stat-value" style="font-size:20px;">Never</div>
      <% end %>
      <div class="stat-delta">Most recent scan</div>
    </div>
    <div class="stat-card yellow">
      <div class="stat-label">Org Users</div>
      <div class="stat-value"><%= @users_count || 0 %></div>
      <div class="stat-delta">Team members</div>
    </div>
    <div class="stat-card orange">
      <div class="stat-label">Active Scans</div>
      <div class="stat-value"><%= @active_scans %></div>
      <div class="stat-delta"><%= @active_scans.to_i > 0 ? 'Currently running' : 'No scans running' %></div>
    </div>
  </div>

  <!-- Recent Vulnerabilities -->
  <div class="section-header">Recent Vulnerabilities</div>
  <div class="main-card" style="padding:0;overflow:hidden;">
    <% if @recent_findings.any? %>
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="border-bottom:1px solid var(--border);background:var(--surface2);">
            <th style="padding:10px 16px;text-align:left;font-family:var(--mono);font-size:11px;color:var(--muted);font-weight:500;">SEVERITY</th>
            <th style="padding:10px 16px;text-align:left;font-family:var(--mono);font-size:11px;color:var(--muted);font-weight:500;">ASSET</th>
            <th style="padding:10px 16px;text-align:left;font-family:var(--mono);font-size:11px;color:var(--muted);font-weight:500;">EXPLOIT</th>
            <th style="padding:10px 16px;text-align:left;font-family:var(--mono);font-size:11px;color:var(--muted);font-weight:500;">DISCOVERED</th>
            <th style="padding:10px 16px;text-align:left;font-family:var(--mono);font-size:11px;color:var(--muted);font-weight:500;">STATUS</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_findings.each do |f| %>
            <% sev_color = { 'critical' => 'var(--red)', 'high' => 'var(--orange)', 'medium' => 'var(--yellow)', 'low' => 'var(--teal)' }[f.severity&.downcase] || 'var(--muted)' %>
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:10px 16px;">
                <span style="font-family:var(--mono);font-size:11px;font-weight:700;color:<%= sev_color %>;text-transform:uppercase;"><%= f.severity %></span>
              </td>
              <td style="padding:10px 16px;font-family:var(--mono);color:var(--text);"><%= f.asset&.ip_address || '—' %></td>
              <td style="padding:10px 16px;color:var(--text);"><%= f.exploit&.name || '—' %></td>
              <td style="padding:10px 16px;color:var(--muted);font-size:12px;"><%= f.discovered_at ? time_ago_in_words(f.discovered_at) + ' ago' : '—' %></td>
              <td style="padding:10px 16px;">
                <span style="font-family:var(--mono);font-size:11px;color:<%= f.status == 'open' ? 'var(--red)' : 'var(--green)' %>;"><%= f.status&.upcase %></span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div style="padding:32px;text-align:center;color:var(--muted);font-size:13px;">
        No vulnerabilities found yet — run a scan to see results here.
      </div>
    <% end %>
  </div>

  <!-- Bottom Row -->
  <div class="bottom-row">
    <!-- Recent Activity -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">Recent Activity</div>
        <div class="panel-sub">LAST 24 HRS</div>
      </div>
      <% if @recent_activity.any? %>
        <% @recent_activity.each do |item| %>
          <div class="activity-item">
            <div class="activity-dot dot-<%= item[:color] %>"></div>
            <div>
              <% if item[:scan] %>
                <div class="activity-text">Scan <strong><%= item[:scan].scan_name %></strong> <%= item[:scan].status %></div>
                <div class="activity-time"><%= item[:scan].start_time ? time_ago_in_words(item[:scan].start_time) + ' ago' : '—' %></div>
              <% elsif item[:agent] %>
                <div class="activity-text">Agent <strong><%= item[:agent].agent_id.first(8) %>&hellip;</strong> last heartbeat</div>
                <div class="activity-time"><%= time_ago_in_words(item[:agent].last_seen) %> ago</div>
              <% elsif item[:session] %>
                <div class="activity-text">User <strong><%= item[:session].user.name %></strong> signed in</div>
                <div class="activity-time"><%= time_ago_in_words(item[:session].created_at) %> ago</div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="activity-item">
          <div class="activity-dot dot-gray"></div>
          <div>
            <div class="activity-text">No activity yet</div>
            <div class="activity-time">—</div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Quick Actions -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">Quick Actions</div>
        <div class="panel-sub">SHORTCUTS</div>
      </div>

      <div style="padding: 8px 0;">
        <% if admin? %>
          <a href="<%= new_asset_path %>" class="quick-btn">
            <div class="quick-btn-icon">+</div>
            <span class="quick-btn-label">Add New Asset</span>
            <span class="quick-btn-arrow">→</span>
          </a>

          <a href="<%= scans_path rescue '#' %>" class="quick-btn">
            <div class="quick-btn-icon">▶️</div>
            <span class="quick-btn-label">Start New Scan</span>
            <span class="quick-btn-arrow">→</span>
          </a>

          <a href="<%= agents_path rescue '#' %>" class="quick-btn">
            <div class="quick-btn-icon">
              <%= image_tag 'SDimagesWhite/Agent.png', alt: '', class: 'quick-icon-img icon-white' %>
              <%= image_tag 'SDimagesBlack/AgentsBlack.png', alt: '', class: 'quick-icon-img icon-black' %>
            </div>
            <span class="quick-btn-label">View Agents Status</span>
            <span class="quick-btn-arrow">→</span>
          </a>
        <% end %>
        <a href="<%= reports_path rescue '#' %>" class="quick-btn">
          <div class="quick-btn-icon">
            <%= image_tag 'SDimagesWhite/VIewReportsWhite.png', alt: '', class: 'quick-icon-img icon-white' %>
            <%= image_tag 'SDimagesBlack/ViewReportBlack.png', alt: '', class: 'quick-icon-img icon-black' %>
          </div>
          <span class="quick-btn-label">Latest Report</span>
          <span class="quick-btn-arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  function updateClock() {
    const now = new Date();
    document.getElementById('clock').textContent =
      now.toLocaleTimeString('en-US', { hour12: false });
  }
  updateClock();
  setInterval(updateClock, 1000);
</script>
