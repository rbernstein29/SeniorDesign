<% content_for :title, "Aegis - Dashboard" %>

<%= render 'shared/sidebar', current_page: 'home' %>

<div class="layout">
  <!-- Top Bar -->
  <div class="topbar">
    <div class="topbar-brand">
      <%= image_tag 'logo_dark_mode.png',  alt: 'Aegis', class: 'brand-logo logo-dark' %>
      <%= image_tag 'logo_light_mode.png', alt: 'Aegis', class: 'brand-logo logo-light' %>
      <div>
        <div class="brand-name">Aegis</div>
        <div class="brand-version">SECURITY PLATFORM v1.0</div>
      </div>
    </div>
    <div class="topbar-meta">
      <div class="live-badge">
        <div class="live-dot"></div>
        SYSTEMS ONLINE
      </div>
      <div class="topbar-time" id="clock"></div>
    </div>
  </div>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-greeting">Welcome back, <%= Current.session&.user&.name&.split(' ')&.first&.capitalize || 'Analyst' %></div>
    <h1 class="hero-title">Security Operations Center</h1>
    <p class="hero-sub">Monitor vulnerabilities, manage assets, and coordinate scanning agents from a single command center.</p>
  </div>

  <!-- Stats -->
  <% connected = @agents&.count(&:connected?) || 0 %>
  <div class="stats-row">
    <div class="stat-card green">
      <div class="stat-label">Total Assets</div>
      <div class="stat-value"><%= @assets&.count || 0 %></div>
      <div class="stat-delta up">Configured targets</div>
    </div>
    <div class="stat-card orange">
      <div class="stat-label">Scan-Ready Assets</div>
      <% scan_ready = @assets&.count { |a| a.scan_config.present? } || 0 %>
      <div class="stat-value"><%= scan_ready %></div>
      <div class="stat-delta">With scan config</div>
    </div>
    <div class="stat-card cyan">
      <div class="stat-label">Total Sites</div>
      <div class="stat-value"><%= @sites&.count || 0 %></div>
      <div class="stat-delta">Network sites</div>
    </div>
    <div class="stat-card magenta">
      <div class="stat-label">Total Agents</div>
      <div class="stat-value"><%= @agents&.count || 0 %></div>
      <div class="stat-delta">Registered agents</div>
    </div>
    <div class="stat-card green">
      <div class="stat-label">Connected Agents</div>
      <div class="stat-value"><%= connected %></div>
      <div class="stat-delta <%= connected > 0 ? 'up' : '' %>"><%= connected > 0 ? 'Online now' : 'None online' %></div>
    </div>
    <div class="stat-card red">
      <div class="stat-label">Offline Agents</div>
      <% offline = (@agents&.count || 0) - connected %>
      <div class="stat-value"><%= offline %></div>
      <div class="stat-delta <%= offline > 0 ? 'bad' : '' %>"><%= offline > 0 ? 'Not reachable' : 'All online' %></div>
    </div>
    <div class="stat-card violet">
      <div class="stat-label">Total Reports</div>
      <div class="stat-value"><%= @reports&.count || 0 %></div>
      <div class="stat-delta">Scan reports</div>
    </div>
    <div class="stat-card orange">
      <div class="stat-label">Last Scan</div>
      <% if @last_scan %>
        <div class="stat-value" style="font-size:16px;line-height:1.3;margin-top:4px;"><%= time_ago_in_words(@last_scan) %> ago</div>
      <% else %>
        <div class="stat-value" style="font-size:20px;">Never</div>
      <% end %>
      <div class="stat-delta">Most recent scan</div>
    </div>
    <div class="stat-card teal">
      <div class="stat-label">Org Users</div>
      <div class="stat-value"><%= @users_count || 0 %></div>
      <div class="stat-delta">Team members</div>
    </div>
    <div class="stat-card red">
      <div class="stat-label">Active Scans</div>
      <div class="stat-value"><%= @active_scans %></div>
      <div class="stat-delta"><%= @active_scans.to_i > 0 ? 'Currently running' : 'No scans running' %></div>
    </div>
  </div>

  <!-- Navigation Cards -->
  <div class="section-header">Navigate</div>
  <div class="nav-grid">

    <% if admin? %>
      <a href="<%= scans_path rescue '#' %>" class="nav-card nav-orange">
        <div class="card-arrow">→</div>
        <div class="card-icon-wrap">
          <%= image_tag 'SDimagesWhite/snanerWhite.png', alt: '', class: 'card-icon-img icon-white' %>
          <%= image_tag 'SDimagesBlack/ScansBlack.png', alt: '', class: 'card-icon-img icon-black' %>
        </div>
        <div>
          <div class="card-title">Run a Scan</div>
          <div class="card-desc">Configure and launch vulnerability scans against your targets.</div>
        </div>
        <div class="card-tag">SCANNER</div>
      </a>

      <a href="<%= assets_path %>" class="nav-card nav-cyan">
        <div class="card-arrow">→</div>
        <div class="card-icon-wrap">
          <%= image_tag 'SDimagesWhite/AssetMangerWhite.png', alt: '', class: 'card-icon-img icon-white' %>
          <%= image_tag 'SDimagesBlack/AssetMangerBLack.png', alt: '', class: 'card-icon-img icon-black' %>
        </div>
        <div>
          <div class="card-title">Asset Management</div>
          <div class="card-desc">Add, edit, and organize your network targets and scan configurations.</div>
        </div>
        <div class="card-tag">ASSETS</div>
      </a>

      <a href="<%= agents_path rescue '#' %>" class="nav-card nav-magenta">
        <div class="card-arrow">→</div>
        <div class="card-icon-wrap">
          <%= image_tag 'SDimagesWhite/Agent.png', alt: '', class: 'card-icon-img icon-white' %>
          <%= image_tag 'SDimagesBlack/AgentsBlack.png', alt: '', class: 'card-icon-img icon-black' %>
        </div>
        <div>
          <div class="card-title">Agents</div>
          <div class="card-desc">Manage distributed scanning agents deployed across your network.</div>
        </div>
        <div class="card-tag">AGENTS</div>
      </a>

      <a href="<%= sites_path rescue '#' %>" class="nav-card nav-teal">
        <div class="card-arrow">→</div>
        <div class="card-icon-wrap">
          <%= image_tag 'SDimagesWhite/SitesWhite.png', alt: '', class: 'card-icon-img icon-white' %>
          <%= image_tag 'SDimagesBlack/SitesBlack.png', alt: '', class: 'card-icon-img icon-black' %>
        </div>
        <div>
          <div class="card-title">Network Sites</div>
          <div class="card-desc">Organize assets by physical or logical network location.</div>
        </div>
        <div class="card-tag">NETWORK</div>
      </a>

      <a href="<%= scanner_path rescue '#' %>" class="nav-card nav-red">
        <div class="card-arrow">→</div>
        <div class="card-icon-wrap">
          <%= image_tag 'SDimagesWhite/snanerWhite.png', alt: '', class: 'card-icon-img icon-white' %>
          <%= image_tag 'SDimagesBlack/ScansBlack.png', alt: '', class: 'card-icon-img icon-black' %>
        </div>
        <div>
          <div class="card-title">Scanner</div>
          <div class="card-desc">Configure scan parameters and review live scanner status.</div>
        </div>
        <div class="card-tag">SCANNER</div>
      </a>
    <% end %>

    <a href="<%= reports_path rescue '#' %>" class="nav-card nav-violet">
      <div class="card-arrow">→</div>
      <div class="card-icon-wrap">
        <%= image_tag 'SDimagesWhite/VIewReportsWhite.png', alt: '', class: 'card-icon-img icon-white' %>
        <%= image_tag 'SDimagesBlack/ViewReportBlack.png', alt: '', class: 'card-icon-img icon-black' %>
      </div>
      <div>
        <div class="card-title">View Reports</div>
        <div class="card-desc">Review scan results, vulnerability findings, and remediation data.</div>
      </div>
      <div class="card-tag">REPORTS</div>
    </a>

    <% if admin? %>
      <a href="<%= read_only_accounts_path rescue '#' %>" class="nav-card nav-yellow">
        <div class="card-arrow">→</div>
        <div class="card-icon-wrap">
          <%= image_tag 'SDimagesWhite/ConfigureAccountWhite.png', alt: '', class: 'card-icon-img icon-white' %>
          <%= image_tag 'SDimagesBlack/ConfigureAccounts.png', alt: '', class: 'card-icon-img icon-black' %>
        </div>
        <div>
          <div class="card-title">Configure Accounts</div>
          <div class="card-desc">Create and delete read-only accounts.</div>
        </div>
        <div class="card-tag">CONFIG</div>
      </a>
    <% end %>

    <a href="<%= settings_path rescue '#' %>" class="nav-card nav-blue">
      <div class="card-arrow">→</div>
      <div class="card-icon-wrap">
        <%= image_tag 'SDimagesWhite/SettingsWhite.png', alt: '', class: 'card-icon-img icon-white' %>
        <%= image_tag 'SDimagesBlack/SettingsBlack.png', alt: '', class: 'card-icon-img icon-black' %>
      </div>
      <div>
        <div class="card-title">Settings</div>
        <div class="card-desc">Configure scanner options, API keys, notification preferences, and more.</div>
      </div>
      <div class="card-tag">CONFIG</div>
    </a>

  </div>

  <!-- Bottom Row -->
  <div class="bottom-row">
    <!-- Recent Activity -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">Recent Activity</div>
        <div class="panel-sub">LAST 24 HRS</div>
      </div>
      <div class="activity-item">
        <div class="activity-dot dot-blue"></div>
        <div>
          <div class="activity-text">Platform initialized and <strong>ready for scanning</strong></div>
          <div class="activity-time">just now</div>
        </div>
      </div>
      <div class="activity-item">
        <div class="activity-dot dot-green"></div>
        <div>
          <div class="activity-text">Asset management module <strong>loaded successfully</strong></div>
          <div class="activity-time">1 min ago</div>
        </div>
      </div>
      <div class="activity-item">
        <div class="activity-dot dot-green"></div>
        <div>
          <div class="activity-text">Database connection <strong>established</strong></div>
          <div class="activity-time">2 min ago</div>
        </div>
      </div>
      <div class="activity-item">
        <div class="activity-dot dot-orange"></div>
        <div>
          <div class="activity-text">No scans have been run yet — <strong>configure an asset to begin</strong></div>
          <div class="activity-time">—</div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">Quick Actions</div>
        <div class="panel-sub">SHORTCUTS</div>
      </div>

      <div style="padding: 8px 0;">
        <% if admin? %>
          <a href="<%= new_asset_path %>" class="quick-btn">
            <div class="quick-btn-icon">➕</div>
            <span class="quick-btn-label">Add New Asset</span>
            <span class="quick-btn-arrow">→</span>
          </a>

          <a href="<%= scans_path rescue '#' %>" class="quick-btn">
            <div class="quick-btn-icon">▶️</div>
            <span class="quick-btn-label">Start New Scan</span>
            <span class="quick-btn-arrow">→</span>
          </a>

          <a href="<%= agents_path rescue '#' %>" class="quick-btn">
            <div class="quick-btn-icon">
              <%= image_tag 'SDimagesWhite/Agent.png', alt: '', class: 'quick-icon-img icon-white' %>
              <%= image_tag 'SDimagesBlack/AgentsBlack.png', alt: '', class: 'quick-icon-img icon-black' %>
            </div>
            <span class="quick-btn-label">View Agents Status</span>
            <span class="quick-btn-arrow">→</span>
          </a>
        <% end %>
        <a href="<%= reports_path rescue '#' %>" class="quick-btn">
          <div class="quick-btn-icon">
            <%= image_tag 'SDimagesWhite/VIewReportsWhite.png', alt: '', class: 'quick-icon-img icon-white' %>
            <%= image_tag 'SDimagesBlack/ViewReportBlack.png', alt: '', class: 'quick-icon-img icon-black' %>
          </div>
          <span class="quick-btn-label">Latest Report</span>
          <span class="quick-btn-arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  function updateClock() {
    const now = new Date();
    document.getElementById('clock').textContent =
      now.toLocaleTimeString('en-US', { hour12: false });
  }
  updateClock();
  setInterval(updateClock, 1000);
</script>
