<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% content_for :title, "Aegis - Read-Only Users" %>
    <%= csrf_meta_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Sora:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg:        #080c14;
            --surface:   #0d1525;
            --surface2:  #111b30;
            --border:    rgba(59,130,246,0.15);
            --blue:      #3b82f6;
            --blue-dim:  rgba(59,130,246,0.12);
            --blue-glow: rgba(59,130,246,0.35);
            --green:     #10b981;
            --orange:    #f59e0b;
            --red:       #ef4444;
            --text:      #e2e8f0;
            --muted:     #64748b;
            --mono:      'JetBrains Mono', monospace;
            --sans:      'Sora', sans-serif;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: var(--sans);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: 0;
        }

        .layout {
            position: relative;
            z-index: 1;
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 30px 40px 84px;
        }

        .page-header {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 28px 36px;
            border-radius: 16px;
            margin-bottom: 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .page-title { font-size: 26px; font-weight: 700; color: #f1f5f9; }
        .page-sub { color: var(--muted); margin-top: 4px; font-size: 13px; font-family: var(--mono); }

        .btn {
            padding: 11px 22px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            border: none;
            font-family: var(--sans);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--blue), #1d4ed8);
            color: white;
            box-shadow: 0 4px 16px var(--blue-glow);
        }

        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px var(--blue-glow); }

        .btn-danger {
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.25);
            color: #f87171;
        }

        .btn-danger:hover { background: rgba(239,68,68,0.2); }
        .btn-sm { padding: 6px 14px; font-size: 12px; font-family: var(--mono); }

        .main-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
        }

        .card-header {
            padding: 20px 28px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-title { font-size: 15px; font-weight: 600; color: #f1f5f9; }
        .card-subtitle { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 1px; }

        table { width: 100%; border-collapse: collapse; }
        thead { background: rgba(255,255,255,0.03); }

        th {
            padding: 14px 20px;
            text-align: left;
            font-family: var(--mono);
            font-weight: 600;
            font-size: 10px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        td {
            padding: 18px 20px;
            border-top: 1px solid rgba(255,255,255,0.04);
            font-size: 13px;
            color: #cbd5e1;
        }

        tbody tr:hover { background: rgba(59,130,246,0.04); }

        /* Alerts */

        .alert {
            background: rgba(46, 204, 113, .12);
            border: 1px solid rgba(46, 204, 113, .4);
            color: #baf3cd;
            padding: 10px;
            border-radius: 12px;
            font-size: 13px;
            margin-top: 20px;
        }

        /* ── Info Box ── */
        .info-box {
            background: rgba(59,130,246,0.06);
            border: 1px solid rgba(59,130,246,0.2);
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 28px;
            display: flex;
            gap: 16px;
            align-items: flex-start;
        }

        .info-box-icon {
            font-size: 22px;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .info-box-title {
            font-size: 14px;
            font-weight: 700;
            color: #93c5fd;
            margin-bottom: 10px;
        }

        .info-box-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .info-box-list li {
            font-size: 13px;
            color: #7dd3fc;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }

        .info-box-list li::before {
            content: '//';
            font-family: var(--mono);
            font-size: 11px;
            color: var(--blue);
            flex-shrink: 0;
            margin-top: 1px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 5px 12px;
            border-radius: 20px;
            font-family: var(--mono);
            font-size: 11px;
            font-weight: 700;
        }

        .status-active {
            background: rgba(16,185,129,0.12);
            border: 1px solid rgba(16,185,129,0.25);
            color: #34d399;
        }

        .status-inactive {
            background: rgba(100,116,139,0.12);
            border: 1px solid rgba(100,116,139,0.2);
            color: var(--muted);
        }

        .status-dot { width: 7px; height: 7px; border-radius: 50%; }
        .dot-green { background: var(--green); box-shadow: 0 0 6px var(--green); animation: pulse 2s infinite; }
        .dot-gray { background: var(--muted); }

        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

        .state-box { padding: 80px 40px; text-align: center; }
        .state-icon { font-size: 48px; margin-bottom: 16px; display: block; opacity: 0.6; }
        .state-title { font-size: 18px; font-weight: 600; color: #94a3b8; margin-bottom: 8px; }
        .state-sub { font-size: 13px; color: var(--muted); margin-bottom: 24px; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .page-header { animation: fadeUp 0.4s ease both; }
        .main-card   { animation: fadeUp 0.4s 0.1s ease both; }
    </style>
</head>
<body>

    <%= render 'shared/sidebar', current_page: 'read_only_accounts' %>

    <div class="layout">

        <div class="page-header">
            <div>
                <div class="page-title">👥 Configure Read-Only Users</div>
                <div class="page-sub">// manage read-only accounts in your organization</div>
                <% if flash[:alert] %>
                    <div class="alert">
                        <%= flash[:alert] %>
                    </div>
                <% end %>
            </div>
            <%= link_to "➕ Add User", create_ro_account_path, class: "btn btn-primary" %>
        </div>

        <!-- Info Box -->
        <div class="info-box">
            <ul class="info-box-list">
                <li>Read-only accounts are able to view and download scan reports</li>
                <li>They are not able to create assets or run scans</li>
            </ul>
        </div>

        <div class="main-card">
            <div class="card-header">
                <div>
                    <div class="card-title">Read-Only Users</div>
                    <div class="card-subtitle"><%= @read_only_users.count %> USERS</div>
                </div>
            </div>

            <% if @read_only_users.any? %>
                <div style="overflow:auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% @read_only_users.each do |user| %>
                                <tr>
                                    <td><%= user.name %></td>
                                    <td style="font-family:var(--mono);font-size:12px;color:#93c5fd;">
                                        <%= user.email_address %>
                                    </td>
                                    <td style="font-family:var(--mono);font-size:12px;color:var(--muted);">
                                        <%= user.created_at.strftime("%b %d, %Y") %>
                                    </td>
                                    <td>
                                        <%= button_to "🗑 Delete", delete_read_only_account_path(user), method: :delete,
                                            class: "btn btn-danger btn-sm",
                                            data: { confirm: "Delete #{user.name}? This cannot be undone." } %>
                                    </td>
                                </tr>
                            <% end %>
                        </tbody>
                    </table>
                </div>
            <% else %>
                <div class="state-box">
                    <span class="state-icon">👥</span>
                    <div class="state-title">No Read-Only Users</div>
                    <div class="state-sub">Add a read-only user to give limited access to your organization</div>
                    <%= link_to "➕ Add Read-Only User", create_ro_account_path, class: "btn btn-primary" %>
                </div>
            <% end %>
        </div>
    </div>

</body>
</html>