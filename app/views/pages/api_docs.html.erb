<% content_for :title, "Aegis - API Docs" %>

<% content_for :head do %>
<style>
  .api-docs-wrap {
    display: flex;
    gap: 0;
    min-height: 100vh;
    align-items: flex-start;
  }
  .api-toc {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 24px;
    align-self: flex-start;
    padding: 0 0 40px 0;
  }
  .api-toc-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
    padding: 0 8px;
  }
  .api-toc a {
    display: block;
    padding: 5px 8px;
    border-radius: 6px;
    font-size: 12px;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .api-toc a:hover { color: var(--text); background: var(--surface2); }
  .api-toc a.active { color: var(--cyan); background: rgba(34,211,238,0.08); }
  .api-toc-section {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 12px 8px 4px;
  }
  .api-content {
    flex: 1;
    min-width: 0;
    padding: 0 0 80px 32px;
  }
  .api-section {
    margin-bottom: 56px;
    scroll-margin-top: 24px;
  }
  .api-section-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }
  .api-section-sub {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 20px;
  }
  .api-endpoint {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 16px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .api-endpoint:hover { border-color: rgba(255,255,255,0.18); }
  .api-endpoint-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    cursor: pointer;
    user-select: none;
  }
  .api-endpoint-header:hover { background: var(--surface2); }
  .method-badge {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
    min-width: 52px;
    text-align: center;
  }
  .method-get    { background: rgba(34,197,94,0.18);  color: #4ade80; }
  .method-post   { background: rgba(79,134,247,0.18); color: #7cabfa; }
  .method-delete { background: rgba(239,68,68,0.18);  color: #f87171; }
  .method-patch  { background: rgba(245,158,11,0.18); color: #fbbf24; }
  .endpoint-path {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--text);
    flex: 1;
  }
  .endpoint-path .path-param { color: var(--cyan); }
  .endpoint-desc {
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
  }
  .api-endpoint-body {
    border-top: 1px solid var(--border);
    padding: 18px;
    display: none;
  }
  .api-endpoint-body.open { display: block; }
  .ep-desc {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 16px;
    line-height: 1.5;
  }
  .param-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    margin-bottom: 16px;
  }
  .param-table th {
    text-align: left;
    padding: 6px 10px;
    background: var(--surface2);
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.04em;
    font-size: 11px;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
  }
  .param-table td {
    padding: 7px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    color: var(--text);
    vertical-align: top;
  }
  .param-table tr:last-child td { border-bottom: none; }
  .param-name { font-family: var(--mono); color: var(--cyan); }
  .param-type { font-family: var(--mono); color: var(--muted); font-size: 11px; }
  .param-required {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 5px;
    border-radius: 3px;
    letter-spacing: 0.04em;
  }
  .req  { background: rgba(239,68,68,0.18);  color: #f87171; }
  .opt  { background: rgba(136,136,136,0.15); color: var(--muted); }
  .code-block {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px 14px;
    font-family: var(--mono);
    font-size: 12px;
    color: #a8d8a8;
    overflow-x: auto;
    white-space: pre;
    margin-bottom: 12px;
  }
  .code-block-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .auth-box {
    background: rgba(34,211,238,0.06);
    border: 1px solid rgba(34,211,238,0.2);
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 32px;
  }
  .auth-box-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--cyan);
    margin-bottom: 8px;
  }
  .auth-box p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 10px;
  }
  .access-badge {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 3px;
    letter-spacing: 0.04em;
    vertical-align: middle;
  }
  .access-admin    { background: rgba(239,68,68,0.18);  color: #f87171; }
  .access-all      { background: rgba(34,197,94,0.18);  color: #4ade80; }
</style>
<% end %>

<%= render 'shared/sidebar', current_page: 'api_docs' %>

<div class="layout page-teal">
  <div class="page-header">
    <div>
      <div class="page-title">API Reference</div>
      <div class="page-sub">Full REST API — authenticate with your API key in the URL path</div>
    </div>
  </div>

  <div class="api-docs-wrap">

    <!-- Table of Contents -->
    <nav class="api-toc" id="api-toc">
      <div class="api-toc-title">Contents</div>
      <a href="#auth">Authentication</a>
      <div class="api-toc-section">Resources</div>
      <a href="#account">Account</a>
      <a href="#assets">Assets</a>
      <a href="#sites">Sites</a>
      <a href="#scan-profiles">Scan Profiles</a>
      <a href="#scans">Scans</a>
      <a href="#reports">Reports</a>
      <a href="#findings">Findings</a>
      <a href="#exploits">Exploits</a>
      <a href="#code-analysis">Code Analysis</a>
      <a href="#agents">Agents</a>
    </nav>

    <!-- Content -->
    <div class="api-content">

      <!-- Authentication -->
      <div class="api-section" id="auth">
        <div class="api-section-title">Authentication</div>
        <div class="auth-box">
          <div class="auth-box-title">API Key Authentication</div>
          <p>Every request must include your API key as the second path segment:</p>
          <div class="code-block">https://your-server/api/<span style="color:var(--cyan)">{api_key}</span>/resource</div>
          <p>Generate or regenerate your API key in <a href="<%= settings_path %>" style="color:var(--cyan);">Settings → Account</a>. Keys are unique per user and scoped to your organization.</p>
          <p>Invalid keys return <code style="font-family:var(--mono);color:#f87171;">401 Unauthorized</code>. Write operations (POST/DELETE) require an <span class="access-badge access-admin">admin</span> account. Read operations are available to all <span class="access-badge access-all">all users</span>.</p>
        </div>
      </div>

      <!-- Account -->
      <div class="api-section" id="account">
        <div class="api-section-title">Account</div>
        <div class="api-section-sub">Read current user and organization info. <span class="access-badge access-all">all users</span></div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-get">GET</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/account</span>
            <span class="endpoint-desc">Current user &amp; org</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Returns the authenticated user's profile and organization details.</div>
            <div class="code-block-label">Example Request</div>
            <div class="code-block">curl https://your-server/api/YOUR_KEY/account</div>
            <div class="code-block-label">Example Response</div>
            <div class="code-block">{
  "account": {
    "id": 1,
    "name": "Jane Smith",
    "email": "jane@example.com",
    "access_level": "admin",
    "organization": {
      "id": 1,
      "name": "Acme Corp",
      "domain": "acme.com"
    }
  }
}</div>
          </div>
        </div>
      </div>

      <!-- Assets -->
      <div class="api-section" id="assets">
        <div class="api-section-title">Assets</div>
        <div class="api-section-sub">Manage network targets. Read: <span class="access-badge access-all">all users</span> &nbsp; Write: <span class="access-badge access-admin">admin</span></div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-get">GET</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/assets</span>
            <span class="endpoint-desc">List all assets</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Returns all assets in your organization. Optionally filter by CIDR range — returns a count instead of full list.</div>
            <table class="param-table">
              <tr><th>Parameter</th><th>Type</th><th>Required</th><th>Description</th></tr>
              <tr><td class="param-name">cidr</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Filter to assets in range — returns <code style="font-family:var(--mono);">{ count: N }</code></td></tr>
            </table>
            <div class="code-block-label">Example Request</div>
            <div class="code-block">curl https://your-server/api/YOUR_KEY/assets
curl https://your-server/api/YOUR_KEY/assets?cidr=10.0.0.0/24</div>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-get">GET</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/assets/<span class="path-param">{id}</span></span>
            <span class="endpoint-desc">Get asset detail</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Returns a single asset with its last scan summary and finding count.</div>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-post">POST</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/assets</span>
            <span class="endpoint-desc">Create asset(s)</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Create one or more assets. Provide a single IP, a CIDR range (minimum /24), or a hostname. DNS lookup fires automatically when hostname is not provided.</div>
            <table class="param-table">
              <tr><th>Parameter</th><th>Type</th><th>Required</th><th>Description</th></tr>
              <tr><td class="param-name">network</td><td class="param-type">string</td><td><span class="param-required req">required</span></td><td>IP address, CIDR (e.g. 10.0.0.0/24), or hostname</td></tr>
              <tr><td class="param-name">hostname</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Override hostname (skips DNS lookup)</td></tr>
              <tr><td class="param-name">site_id</td><td class="param-type">integer</td><td><span class="param-required opt">optional</span></td><td>Associate with a site</td></tr>
              <tr><td class="param-name">port</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Default port for scanning</td></tr>
              <tr><td class="param-name">os</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Operating system hint</td></tr>
              <tr><td class="param-name">asset_type</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Asset classification</td></tr>
              <tr><td class="param-name">criticality</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Criticality level (default: unknown)</td></tr>
              <tr><td class="param-name">notes</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Free-text notes</td></tr>
            </table>
            <div class="code-block-label">Example Request</div>
            <div class="code-block">curl -X POST https://your-server/api/YOUR_KEY/assets \
  -d "network=10.0.0.1&criticality=high&notes=web+server"

# Add a full /24 subnet
curl -X POST https://your-server/api/YOUR_KEY/assets \
  -d "network=192.168.1.0/24"</div>
            <div class="code-block-label">Example Response</div>
            <div class="code-block">{
  "created": 1,
  "assets": [{ "id": 42, "ip_address": "10.0.0.1", ... }]
}</div>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-delete">DELETE</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/assets/<span class="path-param">{id}</span></span>
            <span class="endpoint-desc">Delete asset</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Permanently deletes an asset and its associated findings.</div>
            <div class="code-block-label">Example Response</div>
            <div class="code-block">{ "deleted": true, "id": 42 }</div>
          </div>
        </div>
      </div>

      <!-- Sites -->
      <div class="api-section" id="sites">
        <div class="api-section-title">Sites</div>
        <div class="api-section-sub">Network segments grouping assets and agents. Read: <span class="access-badge access-all">all users</span> &nbsp; Write: <span class="access-badge access-admin">admin</span></div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-get">GET</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/sites</span>
            <span class="endpoint-desc">List sites</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Returns all sites for your organization with agent and asset counts.</div>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-post">POST</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/sites</span>
            <span class="endpoint-desc">Create site</span>
          </div>
          <div class="api-endpoint-body">
            <table class="param-table">
              <tr><th>Parameter</th><th>Type</th><th>Required</th><th>Description</th></tr>
              <tr><td class="param-name">name</td><td class="param-type">string</td><td><span class="param-required req">required</span></td><td>Site name</td></tr>
              <tr><td class="param-name">network_range</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>CIDR range (e.g. 10.0.0.0/24)</td></tr>
            </table>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-delete">DELETE</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/sites/<span class="path-param">{id}</span></span>
            <span class="endpoint-desc">Delete site</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Deletes a site. Cascades to associated agents and assets.</div>
          </div>
        </div>
      </div>

      <!-- Scan Profiles -->
      <div class="api-section" id="scan-profiles">
        <div class="api-section-title">Scan Profiles</div>
        <div class="api-section-sub">Reusable exploit module sets. <span class="access-badge access-admin">admin</span></div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-get">GET</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/scan-profiles</span>
            <span class="endpoint-desc">List profiles</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Returns all scan profiles for your organization.</div>
            <div class="code-block-label">Example Response</div>
            <div class="code-block">{
  "scan_profiles": [{
    "id": 3,
    "name": "Linux Critical",
    "description": "High-severity Linux exploits",
    "safe_mode": false,
    "exploit_ids": [12, 45, 67],
    "created_at": "2026-01-15T10:00:00Z"
  }]
}</div>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-post">POST</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/scan-profiles</span>
            <span class="endpoint-desc">Create profile</span>
          </div>
          <div class="api-endpoint-body">
            <table class="param-table">
              <tr><th>Parameter</th><th>Type</th><th>Required</th><th>Description</th></tr>
              <tr><td class="param-name">name</td><td class="param-type">string</td><td><span class="param-required req">required</span></td><td>Profile name</td></tr>
              <tr><td class="param-name">description</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Description</td></tr>
              <tr><td class="param-name">safe_mode</td><td class="param-type">boolean</td><td><span class="param-required opt">optional</span></td><td>true = reconnaissance only (default: false)</td></tr>
              <tr><td class="param-name">exploit_ids[]</td><td class="param-type">integer[]</td><td><span class="param-required opt">optional</span></td><td>Array of exploit IDs to include</td></tr>
            </table>
            <div class="code-block-label">Example Request</div>
            <div class="code-block">curl -X POST https://your-server/api/YOUR_KEY/scan-profiles \
  -d "name=Linux+Critical&safe_mode=false&exploit_ids[]=12&exploit_ids[]=45"</div>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-delete">DELETE</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/scan-profiles/<span class="path-param">{id}</span></span>
            <span class="endpoint-desc">Delete profile</span>
          </div>
          <div class="api-endpoint-body"></div>
        </div>
      </div>

      <!-- Scans -->
      <div class="api-section" id="scans">
        <div class="api-section-title">Scans</div>
        <div class="api-section-sub">Execute and monitor vulnerability scans. Read: <span class="access-badge access-all">all users</span> &nbsp; Trigger/Stop: <span class="access-badge access-admin">admin</span></div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-get">GET</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/scans</span>
            <span class="endpoint-desc">List scans + stats</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Returns all scans for your organization with aggregate stats and per-scan progress.</div>
            <div class="code-block-label">Example Response</div>
            <div class="code-block">{
  "stats": { "total": 12, "running": 1, "completed": 10, "failed": 1 },
  "scans": [{
    "id": 7,
    "scan_name": "Scan-2026-04-27",
    "status": "completed",
    "safe_mode": false,
    "total_assets": 5,
    "scanned_assets": 5,
    "findings_count": 3,
    "critical_findings": 1,
    "high_findings": 2,
    "start_time": "2026-04-27T10:00:00Z",
    "end_time": "2026-04-27T10:08:34Z",
    "report_id": 15
  }]
}</div>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-get">GET</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/scans/<span class="path-param">{id}</span></span>
            <span class="endpoint-desc">Get scan status</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Poll this endpoint to track progress of a running scan.</div>
          </div>
        </div>

        <div class="api-endpoint">
          <div class="api-endpoint-header" onclick="toggleEndpoint(this)">
            <span class="method-badge method-post">POST</span>
            <span class="endpoint-path">/api/<span class="path-param">{api_key}</span>/scans/trigger</span>
            <span class="endpoint-desc">Start a scan</span>
          </div>
          <div class="api-endpoint-body">
            <div class="ep-desc">Queues a new scan job. Returns immediately with <code style="font-family:var(--mono);">202 Accepted</code> — poll <code style="font-family:var(--mono);">GET /scans</code> for progress. Safe mode runs auxiliary/reconnaissance modules only (non-destructive).</div>
            <table class="param-table">
              <tr><th>Parameter</th><th>Type</th><th>Required</th><th>Description</th></tr>
              <tr><td class="param-name">asset_ids[]</td><td class="param-type">integer[]</td><td><span class="param-required req">required</span></td><td>IDs of assets to scan</td></tr>
              <tr><td class="param-name">profile_id</td><td class="param-type">integer</td><td><span class="param-required opt">optional</span></td><td>Scan profile to use (sets exploit list and safe_mode)</td></tr>
              <tr><td class="param-name">safe_mode</td><td class="param-type">boolean</td><td><span class="param-required opt">optional</span></td><td>true = recon only (default: false)</td></tr>
              <tr><td class="param-name">platform</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>linux, windows, macos, any (default: any)</td></tr>
              <tr><td class="param-name">severities[]</td><td class="param-type">string[]</td><td><span class="param-required opt">optional</span></td><td>critical, high, medium, low</td></tr>
              <tr><td class="param-name">port_override</td><td class="param-type">string</td><td><span class="param-required opt">optional</span></td><td>Override default port</td></tr>
