<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% content_for :title, "Aegis - Reports" %>
    <%= csrf_meta_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Sora:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg:        #080c14;
            --surface:   #0d1525;
            --border:    rgba(59,130,246,0.15);
            --blue:      #3b82f6;
            --blue-dim:  rgba(59,130,246,0.12);
            --green:     #10b981;
            --text:      #e2e8f0;
            --muted:     #64748b;
            --mono:      'JetBrains Mono', monospace;
            --sans:      'Sora', sans-serif;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--sans); background: var(--bg); color: var(--text); min-height: 100vh; }
        body::before {
            content: '';
            position: fixed; inset: 0;
            background-image:
                linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none; z-index: 0;
        }
        .layout { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 30px 30px 40px 84px; }
        .page-header {
            background: var(--surface); border: 1px solid var(--border);
            padding: 28px 36px; border-radius: 16px; margin-bottom: 28px;
            display: flex; justify-content: space-between; align-items: center;
            animation: fadeUp 0.4s ease both;
        }
        .page-title { font-size: 26px; font-weight: 700; color: #f1f5f9; }
        .page-sub { color: var(--muted); margin-top: 4px; font-size: 13px; font-family: var(--mono); }
        .count-badge {
            font-family: var(--mono); font-size: 13px; color: var(--blue);
            background: var(--blue-dim); border: 1px solid rgba(59,130,246,0.25);
            padding: 6px 14px; border-radius: 20px;
        }
        .main-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 16px; overflow: hidden;
            animation: fadeUp 0.4s 0.08s ease both;
        }
        .card-header {
            padding: 20px 28px; border-bottom: 1px solid rgba(255,255,255,0.06);
            display: flex; align-items: center; justify-content: space-between;
        }
        .card-title { font-size: 15px; font-weight: 600; color: #f1f5f9; }
        .card-subtitle { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 1px; }
        table { width: 100%; border-collapse: collapse; }
        thead { background: rgba(255,255,255,0.03); }
        th {
            padding: 14px 20px; text-align: left; font-family: var(--mono);
            font-weight: 600; font-size: 10px; color: var(--muted);
            text-transform: uppercase; letter-spacing: 1px;
        }
        td { padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.04); font-size: 13px; color: #cbd5e1; }
        tbody tr { transition: background 0.15s; }
        tbody tr:hover { background: rgba(59,130,246,0.04); }
        .file-icon { display: inline-flex; align-items: center; gap: 10px; }
        .file-icon-glyph {
            width: 32px; height: 32px;
            background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25);
            border-radius: 6px; display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-family: var(--mono); font-weight: 700; color: #fbbf24; flex-shrink: 0;
        }
        .file-name { font-family: var(--mono); font-size: 13px; color: #f1f5f9; font-weight: 600; }
        .file-meta { font-size: 11px; color: var(--muted); margin-top: 2px; }
        .type-badge {
            display: inline-block; padding: 3px 10px; border-radius: 20px;
            font-family: var(--mono); font-size: 11px; font-weight: 600;
            background: var(--blue-dim); border: 1px solid rgba(59,130,246,0.25); color: #60a5fa;
        }
        .btn {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 7px 14px; border-radius: 8px; font-family: var(--mono);
            font-size: 11px; font-weight: 600; cursor: pointer; border: none;
            transition: all 0.2s; text-decoration: none; background: none;
        }
        .btn-preview { background: var(--blue-dim); border: 1px solid rgba(59,130,246,0.3); color: #60a5fa; }
        .btn-preview:hover { background: rgba(59,130,246,0.2); border-color: rgba(59,130,246,0.5); }
        .btn-download { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.25); color: #34d399; }
        .btn-download:hover { background: rgba(16,185,129,0.2); border-color: rgba(16,185,129,0.5); }
        .actions { display: flex; gap: 8px; align-items: center; }
        .state-box { padding: 80px 40px; text-align: center; }
        .state-icon { font-size: 48px; margin-bottom: 16px; display: block; opacity: 0.6; }
        .state-title { font-size: 18px; font-weight: 600; color: #94a3b8; margin-bottom: 8px; }
        .state-sub { font-size: 13px; color: var(--muted); }
        /* Modal */
        .modal-backdrop {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.75); backdrop-filter: blur(6px);
            z-index: 1000; align-items: center; justify-content: center;
        }
        .modal-backdrop.open { display: flex; }
        .modal {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 16px; width: 90%; max-width: 860px; max-height: 85vh;
            display: flex; flex-direction: column;
            box-shadow: 0 24px 80px rgba(0,0,0,0.6);
        }
        .modal-header {
            padding: 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.06);
            display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
        }
        .modal-title { font-family: var(--mono); font-size: 14px; font-weight: 600; color: #f1f5f9; }
        .modal-actions { display: flex; gap: 8px; align-items: center; }
        .modal-close {
            background: none; border: 1px solid rgba(255,255,255,0.1); color: var(--muted);
            width: 30px; height: 30px; border-radius: 6px; cursor: pointer;
            display: flex; align-items: center; justify-content: center; font-size: 16px; transition: all 0.2s;
        }
        .modal-close:hover { background: rgba(255,255,255,0.07); color: #e2e8f0; }
        .modal-body { overflow-y: auto; flex: 1; }
        .json-viewer {
            background: #060a10; padding: 24px; font-family: var(--mono);
            font-size: 12px; line-height: 1.7; color: #94a3b8;
            white-space: pre-wrap; word-break: break-all; min-height: 200px;
        }
        .json-key    { color: #60a5fa; }
        .json-string { color: #34d399; }
        .json-number { color: #f59e0b; }
        .json-bool   { color: #c084fc; }
        .json-null   { color: #64748b; }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <%= render 'shared/sidebar', current_page: 'reports' %>

    <div class="layout">

        <div class="page-header">
            <div>
                <div class="page-title">Reports</div>
                <div class="page-sub">// scan output files</div>
            </div>
            <% if @reports&.any? %>
                <span class="count-badge"><%= @reports.count %> file<%= @reports.count == 1 ? '' : 's' %></span>
            <% end %>
        </div>

        <div class="main-card">
            <div class="card-header">
                <div class="card-title">JSON Reports</div>
                <div class="card-subtitle">PREVIEW TO INSPECT &bull; DOWNLOAD TO SAVE</div>
            </div>

            <% if @reports.nil? || @reports.empty? %>
                <div class="state-box">
                    <span class="state-icon">&#x1F4CB;</span>
                    <div class="state-title">No Reports Yet</div>
                    <div class="state-sub">Reports are generated automatically after scans complete.</div>
                </div>
            <% else %>
                <table>
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Type</th>
                            <th>Generated</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @reports.each do |report| %>
                        <tr>
                            <td>
                                <div class="file-icon">
                                    <div class="file-icon-glyph">{ }</div>
                                    <div>
                                        <div class="file-name"><%= report.report_name %>.json</div>
                                        <div class="file-meta">scan_id: <%= report.scan_id || '&mdash;' %></div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="type-badge"><%= report.report_type || 'report' %></span>
                            </td>
                            <td style="font-family: var(--mono); font-size: 12px;">
                                <%= report.generated_at&.strftime("%b %d, %Y  %H:%M") || '&mdash;' %>
                            </td>
                            <td>
                                <div class="actions">
                                    <button class="btn btn-preview"
                                            onclick="openPreview(<%= report.id %>, '<%= j report.report_name %>')">
                                        &#x1F441; Preview
                                    </button>
                                    <button class="btn btn-download"
                                            onclick="downloadReport(<%= report.id %>, '<%= j report.report_name %>')">
                                        &#x2B73; Download
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% end %>
                    </tbody>
                </table>
            <% end %>
        </div>

    </div>

    <!-- Preview Modal -->
    <div class="modal-backdrop" id="previewModal">
        <div class="modal">
            <div class="modal-header">
                <div class="modal-title" id="modalTitle">report.json</div>
                <div class="modal-actions">
                    <button class="btn btn-download" onclick="downloadFromModal()">&#x2B73; Download</button>
                    <button class="modal-close" onclick="closePreview()">&#x2715;</button>
                </div>
            </div>
            <div class="modal-body">
                <div class="json-viewer" id="jsonViewer"></div>
            </div>
        </div>
    </div>

    <script>
        const REPORTS = {
            <% @reports&.each do |report| %>
            "<%= report.id %>": <%= raw json_escape(report.report_data.to_json) %>,
            <% end %>
        };

        let activeId = null;

        function openPreview(id, name) {
            activeId = id;
            document.getElementById('modalTitle').textContent = name + '.json';
            document.getElementById('previewModal').classList.add('open');
            const raw = JSON.stringify(REPORTS[String(id)], null, 2);
            document.getElementById('jsonViewer').innerHTML = syntaxHighlight(raw);
        }

        function closePreview() {
            document.getElementById('previewModal').classList.remove('open');
            activeId = null;
        }

        function downloadReport(id, name) {
            const blob = new Blob([JSON.stringify(REPORTS[String(id)], null, 2)], { type: 'application/json' });
            const url  = URL.createObjectURL(blob);
            const a    = document.createElement('a');
            a.href = url; a.download = name + '.json'; a.click();
            URL.revokeObjectURL(url);
        }

        function downloadFromModal() {
            const name = document.getElementById('modalTitle').textContent.replace(/\.json$/, '');
            downloadReport(activeId, name);
        }

        function syntaxHighlight(json) {
            const esc = json
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;');
            return esc.replace(
                /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
                function(m) {
                    let c = 'json-number';
                    if (/^"/.test(m)) c = /:$/.test(m) ? 'json-key' : 'json-string';
                    else if (/true|false/.test(m)) c = 'json-bool';
                    else if (/null/.test(m))       c = 'json-null';
                    return '<span class="' + c + '">' + m + '</span>';
                }
            );
        }

        document.getElementById('previewModal').addEventListener('click', function(e) {
            if (e.target === this) closePreview();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closePreview();
        });
    </script>

</body>
</html>
