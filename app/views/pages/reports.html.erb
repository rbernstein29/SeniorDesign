<% content_for :title, "Aegis - Reports" %>

<%= render 'shared/sidebar', current_page: 'reports' %>

<div class="layout page-violet">

  <div class="page-header">
    <div>
      <div class="page-title">Reports</div>
      <div class="page-sub">// one report per scan — click to view full findings</div>
    </div>
  </div>

  <!-- Summary stats -->
  <div class="stats-grid">
    <div class="stat-card violet">
      <div class="stat-label">Total Reports</div>
      <div class="stat-number"><%= @reports&.count || 0 %></div>
    </div>
    <div class="stat-card red">
      <div class="stat-label">Critical</div>
      <div class="stat-number"><%= @critical_findings || 0 %></div>
    </div>
    <div class="stat-card orange">
      <div class="stat-label">High</div>
      <div class="stat-number"><%= @high_findings || 0 %></div>
    </div>
    <div class="stat-card purple">
      <div class="stat-label">Medium / Low</div>
      <div class="stat-number"><%= @medium_low_findings || 0 %></div>
    </div>
  </div>

  <!-- Report cards -->
  <% if @reports.nil? || @reports.empty? %>
    <div class="main-card">
      <div class="empty-state">
        <div style="opacity:0.4;margin-bottom:10px;">
          <%= image_tag 'SDimagesWhite/VIewReportsWhite.png', alt: '', class: 'icon-white', style: 'width:40px;height:40px;' %>
          <%= image_tag 'SDimagesBlack/ViewReportBlack.png', alt: '', class: 'icon-black', style: 'width:40px;height:40px;' %>
        </div>
        <h3>No Reports Yet</h3>
        <p>Reports are generated automatically after scans complete.</p>
      </div>
    </div>
  <% else %>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <% @reports.each do |report| %>
        <% scan = report.scan %>
        <div class="main-card" style="padding:0;overflow:hidden;">
          <div style="display:grid;grid-template-columns:1fr auto;gap:16px;padding:16px 20px;align-items:center;flex-wrap:wrap;">

            <!-- Left: name + meta -->
            <div>
              <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:6px;">
                <span style="font-size:15px;font-weight:600;"><%= report.report_name %></span>
                <span class="badge <%= report.safe_mode? ? 'badge-green' : 'badge-red' %>" style="font-size:10px;">
                  <%= report.display_type %>
                </span>
                <% if scan&.retest? %>
                  <span class="badge badge-orange" style="font-size:10px;">RETEST</span>
                <% end %>
              </div>
              <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                <span style="font-family:var(--mono);font-size:11px;color:var(--muted);">
                  <%= report.generated_at&.strftime('%Y-%m-%d %H:%M') || '—' %>
                </span>
                <% if scan %>
                  <span style="font-size:11px;color:var(--muted);"><%= scan.scan_name %></span>
                <% end %>
                <!-- Per-report severity counts from scan record -->
                <% if scan %>
                  <div style="display:flex;gap:8px;align-items:center;">
                    <% if scan.critical_findings.to_i > 0 %>
                      <span style="font-family:var(--mono);font-size:11px;color:var(--red);">
                        C: <%= scan.critical_findings %>
                      </span>
                    <% end %>
                    <% if scan.high_findings.to_i > 0 %>
                      <span style="font-family:var(--mono);font-size:11px;color:var(--orange);">
                        H: <%= scan.high_findings %>
                      </span>
                    <% end %>
                    <% if scan.medium_findings.to_i > 0 %>
                      <span style="font-family:var(--mono);font-size:11px;color:var(--yellow);">
                        M: <%= scan.medium_findings %>
                      </span>
                    <% end %>
                    <% if scan.low_findings.to_i > 0 %>
                      <span style="font-family:var(--mono);font-size:11px;color:var(--teal);">
                        L: <%= scan.low_findings %>
                      </span>
                    <% end %>
                    <% if scan.findings_count.to_i == 0 %>
                      <span style="font-family:var(--mono);font-size:11px;color:var(--muted);">No findings</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Right: actions -->
            <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
              <%= link_to "View Report", report_path(report),
                    style: "padding:5px 12px;border-radius:6px;background:var(--accent);color:#000;font-family:var(--mono);font-size:11px;letter-spacing:1px;text-decoration:none;white-space:nowrap;" %>
              <%= link_to "JSON", download_json_report_path(report),
                    style: "padding:5px 10px;border-radius:6px;border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:11px;text-decoration:none;" %>
              <%= link_to "CSV",  download_csv_report_path(report),
                    style: "padding:5px 10px;border-radius:6px;border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:11px;text-decoration:none;" %>
              <%= link_to "XLSX", download_xlsx_report_path(report),
                    style: "padding:5px 10px;border-radius:6px;border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:11px;text-decoration:none;" %>
              <%= button_to "✕", report_path(report), method: :delete,
                    data: { turbo_confirm: "Delete report '#{report.report_name}'? This cannot be undone." },
                    style: "padding:5px 10px;border-radius:6px;border:1px solid rgba(239,68,68,0.3);background:none;color:var(--red);font-family:var(--mono);font-size:11px;cursor:pointer;" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
