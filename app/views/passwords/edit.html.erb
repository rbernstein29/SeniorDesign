<% content_for :title, "Aegis - Set New Password" %>

<div class="login-wrap">
  <div class="login-card">
    <div class="login-head">
      <div class="login-brand">
        <%= image_tag 'logo_dark_mode.png',  alt: 'Aegis', class: 'login-logo logo-dark' %>
        <%= image_tag 'logo_light_mode.png', alt: 'Aegis', class: 'login-logo logo-light' %>
        <h1>Aegis</h1>
      </div>
      <div class="login-sub">Set new password</div>
    </div>

    <div class="login-body">
      <% if flash[:alert] %>
        <div class="alert-error"><%= flash[:alert] %></div>
      <% end %>

      <%= form_with url: password_path(params[:token]), method: :put do |form| %>
        <div class="field">
          <%= form.password_field :password, class: "input", placeholder: "New password",
              required: true, autocomplete: "new-password", maxlength: 72 %>
        </div>
        <div class="field">
          <%= form.password_field :password_confirmation, class: "input", placeholder: "Confirm new password",
              required: true, autocomplete: "new-password", maxlength: 72 %>
        </div>
        <div class="login-row">
          <%= form.submit "Save password", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
