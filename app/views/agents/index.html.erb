<% content_for :title, "Aegis - Agents" %>

<%= render 'shared/sidebar', current_page: 'agents' %>

<div class="layout">

    <!-- Page Header -->
    <div class="page-header">
        <div>
            <div class="page-title"><%= image_tag 'SDimagesWhite/Agent.png', alt: '', class: 'page-title-img icon-white' %><%= image_tag 'SDimagesBlack/AgentsBlack.png', alt: '', class: 'page-title-img icon-black' %> Network Agents</div>
            <div class="page-sub">Deploy and manage distributed scanning agents</div>
        </div>
        <%= form_with url: agents_path, method: :post, style: "display:flex;gap:10px;align-items:center;" do |f| %>
            <% if @sites.any? %>
                <%= select_tag "agent[site_id]",
                    options_for_select(@sites.map { |s| ["#{s.name}#{s.network_range.present? ? " — #{s.network_range}" : ""}", s.id] }),
                    prompt: "Select site...",
                    style: "background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:10px 14px;border-radius:8px;font-family:var(--mono);font-size:13px;width:240px;outline:none;",
                    required: true %>
                <button type="submit"
                    onclick="return confirm('Deploy a new agent for this site? This will generate SSH keys and a download package.')"
                    class="btn btn-primary">➕ Deploy Agent</button>
            <% else %>
                <%= link_to sites_path, style: "font-family:var(--mono);font-size:12px;color:var(--muted);background:var(--surface2);border:1px solid var(--border);padding:9px 18px;box-sizing:border-box;height:38px;border-radius:8px;text-decoration:none;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;" do %><%= image_tag 'SDimagesWhite/SitesWhite.png', alt: '', class: 'nav-icon-img icon-white' %><%= image_tag 'SDimagesBlack/SitesBlack.png', alt: '', class: 'nav-icon-img icon-black' %> No Available Sites — Create One First<% end %>
                <button type="button" disabled style="opacity:0.35;cursor:not-allowed;box-sizing:border-box;height:38px;" class="btn btn-primary">➕ Deploy Agent</button>
            <% end %>
        <% end %>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Total Agents</div>
            <div class="stat-number" data-stat="total"><%= @agents.count %></div>
        </div>
        <div class="stat-card green">
            <div class="stat-label">Connected</div>
            <div class="stat-number" data-stat="connected"><%= @agents.count(&:connected?) %></div>
        </div>
        <div class="stat-card orange">
            <div class="stat-label">Offline</div>
            <div class="stat-number" data-stat="offline"><%= @agents.count { |a| !a.connected? } %></div>
        </div>
        <div class="stat-card purple">
            <div class="stat-label">Tunnel Ports</div>
            <div class="stat-number" data-stat="tunnel_ports"><%= @agents.count %></div>
        </div>
    </div>

    <!-- Info Box -->
    <div class="info-box">
        <div class="info-box-icon">ℹ️</div>
        <div>
            <div class="info-box-title">What are Network Agents?</div>
            <ul class="info-box-list">
                <li>Deploy agents on private networks to enable scanning without VPN</li>
                <li>Each agent creates a secure SSH tunnel back to this server</li>
                <li>Agents are lightweight Python scripts with pre-configured SSH keys</li>
                <li>Click Deploy New Agent to generate a custom installer package</li>
            </ul>
        </div>
    </div>

    <!-- Agents Table -->
    <div class="main-card">
        <div class="card-header">
            <div class="card-title">Deployed Agents</div>
            <div class="card-subtitle">AUTO-REFRESH: 30s</div>
        </div>

        <div id="agents-container">
            <% if @agents.any? %>
                <div style="overflow:auto;max-height:520px;">
                <table style="width:100%;">
                    <thead>
                        <tr>
                            <th>Agent ID</th>
                            <th>Status</th>
                            <th>Site</th>
                            <th>Platform</th>
                            <th>Hostname</th>
                            <th>Last Seen</th>
                            <th>Tunnel Port</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @agents.each do |agent| %>
                            <% connected = agent.connected? %>
                            <tr data-agent-id="<%= agent.agent_id %>">
                                <td>
                                    <span class="agent-id-cell">
                                        <%= agent.agent_id&.first(8) %>...
                                    </span>
                                </td>
                                <td data-field="status">
                                    <span class="status-badge <%= connected ? 'status-connected' : 'status-disconnected' %>">
                                        <span class="status-dot <%= connected ? 'dot-green' : 'dot-gray' %>"></span>
                                        <%= connected ? 'Connected' : 'Offline' %>
                                    </span>
                                </td>
                                <td>
                                    <span style="font-family:var(--mono);font-size:12px;color:var(--cyan);">
                                        <% if agent.site %>
                                            <%= agent.site.name %><% if agent.site.network_range.present? %> <span style="color:var(--muted);">(<%= agent.site.network_range %>)</span><% end %>
                                        <% else %>
                                            —
                                        <% end %>
                                    </span>
                                </td>
                                <td data-field="platform">
                                    <span class="platform-tag">
                                        <%= agent.platform || '—' %>
                                    </span>
                                </td>
                                <td data-field="hostname"><%= agent.hostname || '—' %></td>
                                <td data-field="last_seen">
                                    <span style="font-family: var(--mono); font-size: 12px; color: var(--muted);">
                                        <%= agent.last_seen ? time_ago_in_words(agent.last_seen) + ' ago' : 'Never' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="tunnel-port">:<%= agent.tunnel_port %></span>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <%= link_to "⬇ Download", download_agent_path(agent),
                                            class: "btn btn-secondary btn-sm" %>
                                        <%= button_to "✕ Delete", agent_path(agent),
                                            method: :delete,
                                            data: { confirm: "Delete this agent? The SSH tunnel will be terminated." },
                                            class: "btn btn-danger btn-sm" %>
                                    </div>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
                </div>
            <% else %>
                <div class="state-box">
                    <span class="state-icon"><%= image_tag 'SDimagesWhite/Agent.png', alt: '', class: 'state-icon-img icon-white' %><%= image_tag 'SDimagesBlack/AgentsBlack.png', alt: '', class: 'state-icon-img icon-black' %></span>
                    <div class="state-title">No Agents Deployed</div>
                    <div class="state-sub">Deploy your first agent to start scanning private networks</div>
                    <%= link_to "➕ Create a Site First, Then Deploy an Agent", sites_path, class: "btn btn-primary" %>
                </div>
            <% end %>
        </div>
    </div>

</div>

<script>
    const POLL_INTERVAL = 30000;
    let countdown = 30;
    const subtitle = document.querySelector('.card-subtitle');

    function updateStats(stats) {
        ['total', 'connected', 'offline', 'tunnel_ports'].forEach(key => {
            const el = document.querySelector(`[data-stat="${key}"]`);
            if (el && stats[key] !== undefined) el.textContent = stats[key];
        });
    }

    function updateAgentRow(agent) {
        const row = document.querySelector(`tr[data-agent-id="${agent.id}"]`);
        if (!row) return;

        const statusCell = row.querySelector('[data-field="status"]');
        if (statusCell) {
            statusCell.innerHTML = `
                <span class="status-badge ${agent.connected ? 'status-connected' : 'status-disconnected'}">
                    <span class="status-dot ${agent.connected ? 'dot-green' : 'dot-gray'}"></span>
                    ${agent.connected ? 'Connected' : 'Offline'}
                </span>`;
        }

        const lastSeenCell = row.querySelector('[data-field="last_seen"]');
        if (lastSeenCell) {
            lastSeenCell.innerHTML = `<span style="font-family:var(--mono);font-size:12px;color:var(--muted);">${agent.last_seen}</span>`;
        }

        const platformCell = row.querySelector('[data-field="platform"]');
        if (platformCell && agent.platform) {
            platformCell.innerHTML = `<span class="platform-tag">${agent.platform}</span>`;
        }

        const hostnameCell = row.querySelector('[data-field="hostname"]');
        if (hostnameCell && agent.hostname) {
            hostnameCell.textContent = agent.hostname;
        }
    }

    function poll() {
        fetch('/agents/status.json', { headers: { 'Accept': 'application/json' } })
            .then(r => r.json())
            .then(data => {
                updateStats(data.stats);
                data.agents.forEach(updateAgentRow);
            })
            .catch(err => console.error('Agent status poll failed:', err));
    }

    setInterval(() => {
        countdown--;
        if (countdown <= 0) countdown = 30;
        if (subtitle) subtitle.textContent = `AUTO-REFRESH: ${countdown}s`;
    }, 1000);

    setInterval(poll, POLL_INTERVAL);

    function initResizableColumns() {
        const table = document.querySelector('table');
        if (!table) return;
        const ths = Array.from(table.querySelectorAll('th'));
        ths.forEach(th => { th.style.width = th.offsetWidth + 'px'; });
        table.style.tableLayout = 'fixed';
        table.style.width = Math.max(
            table.offsetWidth,
            ths.reduce((sum, th) => sum + th.offsetWidth, 0)
        ) + 'px';
        ths.forEach(th => {
            const handle = document.createElement('div');
            handle.className = 'resize-handle';
            th.appendChild(handle);
            let startX, startW, startTableW;
            handle.addEventListener('mousedown', e => {
                startX      = e.clientX;
                startW      = th.offsetWidth;
                startTableW = parseInt(table.style.width, 10);
                handle.classList.add('active');
                const onMove = e => {
                    const newW  = Math.max(40, startW + (e.clientX - startX));
                    const delta = newW - startW;
                    th.style.width    = newW + 'px';
                    table.style.width = (startTableW + delta) + 'px';
                };
                const onUp = () => {
                    handle.classList.remove('active');
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup', onUp);
                };
                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup', onUp);
                e.preventDefault();
            });
        });
    }
    initResizableColumns();
</script>
