<% content_for :title, "Aegis - Asset Details" %>

<%= render 'shared/sidebar', current_page: 'assets' %>

<div class="layout page-cyan">

    <div class="page-header">
        <div>
            <div class="breadcrumb">
                <%= link_to "Asset Management", assets_path %> <span>/</span> <span>Asset #<%= @asset.id %></span>
            </div>
            <div class="page-title">
                <%= image_tag 'SDimagesWhite/AssetMangerWhite.png', alt: '', class: 'page-title-img icon-white' %><%= image_tag 'SDimagesBlack/AssetMangerBLack.png', alt: '', class: 'page-title-img icon-black' %> <%= @asset.ip_address %>
            </div>
            <div class="page-sub">// asset configuration details</div>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
            <%= link_to "← Back to Assets", assets_path, class: "btn btn-secondary" %>
            <%= link_to "▶ Run Scan", scanner_path, class: "btn btn-primary" %>
        </div>
    </div>

    <div class="asset-content-grid">

        <!-- Left Column -->
        <div>
            <div class="card">
                <div class="card-header">
                    <span class="card-header-icon"><%= image_tag 'SDimagesWhite/SettingsWhite.png', alt: '', class: 'hdr-icon-img icon-white' %><%= image_tag 'SDimagesBlack/SettingsBlack.png', alt: '', class: 'hdr-icon-img icon-black' %></span>
                    <span class="card-title">Configuration</span>
                    <span style="font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:1px;">ASSET CONFIG</span>
                </div>
                <div class="card-body">

                    <div class="asset-detail-row">
                        <div class="asset-detail-label">Target</div>
                        <div class="asset-detail-value">
                            <span class="network-code"><%= @asset.ip_address %></span>
                        </div>
                    </div>

                    <div class="asset-detail-row">
                        <div class="asset-detail-label">Hostname</div>
                        <div class="asset-detail-value">
                            <% if @asset.hostname.blank? %>
                                <span style="font-style:italic;opacity:0.5;">Resolving…</span>
                            <% else %>
                                <%= @asset.hostname %>
                            <% end %>
                        </div>
                    </div>

                    <div class="asset-detail-row">
                        <div class="asset-detail-label">Site</div>
                        <div class="asset-detail-value"><%= @asset.site&.name.presence || '—' %></div>
                    </div>

                    <div class="asset-detail-row">
                        <div class="asset-detail-label">Ports</div>
                        <div class="asset-detail-value">
                            <% ports = @asset.scan_config&.dig('port').to_s.split(',') %>
                            <% if ports.any?(&:present?) %>
                                <% ports.each do |port| %>
                                    <span class="asset-port-tag"><%= port.strip %></span>
                                <% end %>
                            <% else %>
                                <span style="opacity:0.5;">Auto</span>
                            <% end %>
                        </div>
                    </div>

                    <div class="asset-detail-row">
                        <div class="asset-detail-label">Operating System</div>
                        <div class="asset-detail-value">
                            <span class="asset-os-tag"><%= @asset.scan_config&.dig('os')&.upcase.presence || '—' %></span>
                        </div>
                    </div>

                    <div class="asset-detail-row">
                        <div class="asset-detail-label">Asset Type</div>
                        <div class="asset-detail-value"><%= @asset.scan_config&.dig('asset_type')&.humanize.presence || '—' %></div>
                    </div>

                    <div class="asset-detail-row">
                        <div class="asset-detail-label">Criticality</div>
                        <div class="asset-detail-value">
                            <% crit = @asset.criticality&.downcase %>
                            <% crit_color = { 'high' => 'red', 'medium' => 'orange', 'low' => 'green' }[crit] || 'muted' %>
                            <span style="font-family:var(--mono);font-size:12px;color:var(--<%= crit_color %>);text-transform:uppercase;"><%= crit.presence || '—' %></span>
                        </div>
                    </div>

                    <% if @asset.notes.present? %>
                        <div class="asset-detail-row">
                            <div class="asset-detail-label">Notes</div>
                            <div class="asset-detail-value" style="white-space:pre-wrap;"><%= @asset.notes %></div>
                        </div>
                    <% end %>

                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-header-icon"><%= image_tag 'SDimagesWhite/VIewReportsWhite.png', alt: '', class: 'hdr-icon-img icon-white' %><%= image_tag 'SDimagesBlack/ViewReportBlack.png', alt: '', class: 'hdr-icon-img icon-black' %></span>
                    <span class="card-title">Scan History</span>
                    <span style="font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:1px;">COMING SOON</span>
                </div>
                <div style="text-align:center;padding:32px 20px;">
                    <div style="font-size:32px;opacity:0.4;margin-bottom:10px;">📭</div>
                    <div style="font-size:13px;color:var(--muted);">Per-asset scan history coming in a future release</div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div>
            <div class="card">
                <div class="card-header">
                    <span class="card-header-icon">📡</span>
                    <span class="card-title">Status</span>
                </div>
                <div class="card-body">
                    <div class="asset-status-panel">
                        <div class="asset-status-icon">🕐</div>
                        <div class="asset-status-label">Last Scan</div>
                        <div class="asset-status-value">
                            <% if @last_scan&.end_time %>
                                <%= time_ago_in_words(@last_scan.end_time) %> ago
                            <% else %>
                                Never
                            <% end %>
                        </div>
                    </div>
                    <div class="asset-status-panel">
                        <div class="asset-status-icon"><%= image_tag 'SDimagesWhite/snanerWhite.png', alt: '', class: 'hdr-icon-img icon-white' %><%= image_tag 'SDimagesBlack/ScansBlack.png', alt: '', class: 'hdr-icon-img icon-black' %></div>
                        <div class="asset-status-label">Findings</div>
                        <div class="asset-status-value"><%= @findings_count > 0 ? @findings_count : '—' %></div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-header-icon">⚡</span>
                    <span class="card-title">Quick Actions</span>
                </div>
                <div class="card-body">

                    <%= link_to scanner_path, class: "asset-quick-action" do %>
                        <div class="asset-qa-icon">
                            <%= image_tag 'SDimagesWhite/PlayWhite.png', alt: '', class: 'icon-white', style: 'width:18px;height:18px;' %>
                            <%= image_tag 'SDimagesBlack/PlayBlack.png', alt: '', class: 'icon-black', style: 'width:18px;height:18px;' %>
                        </div>
                        <span>Run Scan on This Asset</span>
                    <% end %>

                    <%= button_to asset_path(@asset), method: :delete,
                        data: { confirm: "Delete this asset? This cannot be undone." },
                        class: "asset-quick-action asset-quick-action-danger" do %>
                        <div class="asset-qa-icon asset-qa-icon-danger">
                            <%= image_tag 'SDimagesWhite/trashWhite.png', alt: '', class: 'icon-white', style: 'width:18px;height:18px;' %>
                            <%= image_tag 'SDimagesBlack/trashBlack.png', alt: '', class: 'icon-black', style: 'width:18px;height:18px;' %>
                        </div>
                        <span>Delete Asset</span>
                    <% end %>

                </div>
            </div>
        </div>
    </div>
</div>
