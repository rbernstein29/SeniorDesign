<% content_for :title, "Aegis - Add Asset" %>

<%= render 'shared/sidebar', current_page: 'assets' %>

<div class="layout page-cyan">

    <div class="page-header">
        <div>
            <div class="page-title"><%= image_tag 'SDimagesWhite/AssetMangerWhite.png', alt: '', class: 'page-title-img icon-white' %><%= image_tag 'SDimagesBlack/AssetMangerBLack.png', alt: '', class: 'page-title-img icon-black' %> Add Asset</div>
            <div class="page-sub">// configure a new scan target</div>
        </div>
        <%= link_to "← Back to Assets", assets_path, class: "btn btn-secondary" %>
    </div>

    <% if flash[:alert] %>
        <div class="alert alert-error"><%= flash[:alert] %></div>
    <% end %>

    <div class="main-card">
        <div class="card-header">
            <div class="card-title">New Asset</div>
            <div class="card-subtitle">SCAN TARGET</div>
        </div>
        <div class="card-body">
            <%= form_with url: assets_path, method: :post, local: true do %>

                <div style="margin-bottom:24px;">
                    <div style="font-family:var(--mono);font-size:11px;letter-spacing:1px;color:var(--muted);margin-bottom:14px;">REQUIRED</div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label required">IP Address or CIDR Range</label>
                            <%= text_field_tag :network, nil,
                                placeholder: "192.168.1.5  or  192.168.1.0/24",
                                required: true %>
                            <div style="font-size:11px;color:var(--muted);margin-top:4px;">Use /24 or smaller for ranges (e.g. /24 = 254 hosts)</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Site</label>
                            <%= select_tag :site_id,
                                options_for_select([["No site", ""]] + @sites.map { |s| ["#{s.name}#{s.network_range.present? ? " (#{s.network_range})" : ""}", s.id] }),
                                prompt: nil %>
                        </div>
                    </div>
                </div>

                <div style="border-top:1px solid var(--border);padding-top:20px;margin-bottom:24px;">
                    <div style="font-family:var(--mono);font-size:11px;letter-spacing:1px;color:var(--muted);margin-bottom:14px;">OPTIONAL</div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Hostname</label>
                            <%= text_field_tag :hostname, nil, placeholder: "e.g. web-server-01.example.com" %>
                            <div style="font-size:11px;color:var(--muted);margin-top:4px;">Leave blank to auto-detect via DNS</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Ports</label>
                            <%= text_field_tag :port, nil, placeholder: "22, 80, 443" %>
                            <div style="font-size:11px;color:var(--muted);margin-top:4px;">Leave blank to let the scanner choose</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Operating System</label>
                            <%= select_tag :os, options_for_select([
                                ["Unknown", ""],
                                ["Linux", "linux"],
                                ["Windows", "windows"],
                                ["macOS", "macos"]
                            ]) %>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Asset Type</label>
                            <%= select_tag :asset_type, options_for_select([
                                ["Unknown", ""],
                                ["Server", "server"],
                                ["Workstation", "workstation"],
                                ["Network Device", "network_device"]
                            ]) %>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Criticality</label>
                            <%= select_tag :criticality, options_for_select([
                                ["Unknown", "unknown"],
                                ["High", "high"],
                                ["Medium", "medium"],
                                ["Low", "low"]
                            ]) %>
                        </div>
                        <div class="form-group" style="grid-column:1/-1;">
                            <label class="form-label">Notes</label>
                            <%= text_area_tag :notes, nil, placeholder: "Any additional context about this asset", rows: 3 %>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Add Asset</button>
                </div>
            <% end %>
        </div>
    </div>
</div>
