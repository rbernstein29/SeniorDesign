<% content_for :title, "Aegis - Code Analysis" %>

<%= render 'shared/sidebar', current_page: 'code_analysis' %>

<div class="layout page-red">

  <div class="page-header">
    <div>
      <div class="page-title">Code Analysis</div>
      <div class="page-sub">// AI-powered source code vulnerability scanner with PoC generation</div>
    </div>
  </div>

  <!-- Upload card -->
  <div class="main-card" style="margin-bottom:16px;">
    <div class="card-header">
      <div class="card-title">Upload Source File</div>
      <div class="card-subtitle">ANY LANGUAGE &bull; MAX 1 MB</div>
    </div>
    <div class="card-body">
      <%= form_with url: code_analysis_submit_path, method: :post, multipart: true, local: true do |f| %>
        <div class="form-group">
          <label class="form-label">Source Code File</label>
          <div id="drop-zone"
               style="border:2px dashed var(--border);border-radius:8px;padding:32px;text-align:center;cursor:pointer;transition:border-color 0.2s;"
               ondragover="event.preventDefault();this.style.borderColor='var(--accent)';"
               ondragleave="this.style.borderColor='var(--border)';"
               ondrop="handleDrop(event)">
            <div style="font-size:13px;color:var(--muted);margin-bottom:8px;">
              Drag and drop a file here, or click to browse
            </div>
            <div id="file-name" style="font-family:var(--mono);font-size:12px;color:var(--accent);min-height:16px;"></div>
            <%= f.file_field :source_file, id: 'file-input', style: 'display:none;', onchange: 'showFileName(this)' %>
            <button type="button" onclick="document.getElementById('file-input').click()"
                    style="margin-top:10px;padding:6px 16px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text);font-family:var(--mono);font-size:12px;cursor:pointer;">
              Browse
            </button>
          </div>
        </div>
        <div class="form-actions">
          <%= f.submit "Analyze", class: "btn btn-primary", id: "analyze-btn" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Results -->
  <% if defined?(result) && result %>
    <% if result[:error] %>
      <div class="alert alert-error"><%= result[:error] %></div>
    <% elsif result[:clear] %>
      <div class="main-card" style="margin-bottom:16px;">
        <div style="padding:32px;text-align:center;">
          <div style="font-size:48px;margin-bottom:12px;">✓</div>
          <div style="font-size:20px;font-weight:700;color:var(--green);font-family:var(--mono);">CLEAR</div>
          <div style="color:var(--muted);margin-top:8px;">No vulnerabilities detected in <strong><%= defined?(filename) ? filename : 'the uploaded file' %></strong></div>
        </div>
      </div>
    <% else %>
      <div class="main-card">
        <div class="card-header">
          <div class="card-title">Analysis Results</div>
          <div class="card-subtitle"><%= defined?(filename) ? filename : '' %></div>
        </div>
        <div class="card-body">
          <div id="analysis-output" style="white-space:pre-wrap;font-size:13px;line-height:1.7;"><%= h(result[:text]) %></div>
        </div>
      </div>
    <% end %>
  <% end %>

  <div style="font-size:11px;color:var(--muted);margin-top:16px;padding:10px 14px;border:1px solid var(--border);border-radius:6px;">
    Results are AI-generated and should be manually verified before acting on them.
    This tool is for authorized security testing and defensive research only.
  </div>

</div>

<script>
function showFileName(input) {
  var label = document.getElementById('file-name');
  if (input.files && input.files[0]) {
    label.textContent = input.files[0].name + ' (' + (input.files[0].size / 1024).toFixed(1) + ' KB)';
  }
}

function handleDrop(e) {
  e.preventDefault();
  document.getElementById('drop-zone').style.borderColor = 'var(--border)';
  var dt = e.dataTransfer;
  if (dt.files && dt.files[0]) {
    var input = document.getElementById('file-input');
    // Modern browsers support DataTransfer assignment
    try {
      var dataTransfer = new DataTransfer();
      dataTransfer.items.add(dt.files[0]);
      input.files = dataTransfer.files;
    } catch(err) {}
    showFileName(input);
  }
}

document.getElementById('analyze-btn') && document.getElementById('analyze-btn').closest('form').addEventListener('submit', function() {
  var btn = document.getElementById('analyze-btn');
  if (btn) { btn.value = 'Analyzing...'; btn.disabled = true; }
});

// Render bold/code in analysis output
(function() {
  var el = document.getElementById('analysis-output');
  if (!el) return;
  var html = el.innerHTML
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/```(\w*)\n([\s\S]*?)```/g, function(_, lang, code) {
      return '<div style="background:var(--card-bg);border:1px solid var(--border);border-radius:6px;padding:12px;margin:8px 0;overflow-x:auto;">' +
             '<div style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-bottom:6px;text-transform:uppercase;">' + (lang || 'code') + '</div>' +
             '<pre style="margin:0;font-family:var(--mono);font-size:12px;white-space:pre-wrap;">' + code.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</pre>' +
             '</div>';
    });
  el.innerHTML = html;
})();
</script>
